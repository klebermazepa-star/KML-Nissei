/**********************************************************************        
*Programa.: wsinventti0001.p                                          * 
*Descricao: Envia as informar‡äes para a Inventti                     * 
*Autor....: Raimundo                                                  * 
*Data.....: 12/2022                                                   * 
**********************************************************************/
DEF INPUT  PARAMETER p-url                AS CHAR      NO-UNDO.
DEF INPUT  PARAMETER p-longchar           AS LONGCHAR  NO-UNDO.
DEF OUTPUT PARAMETER p-retonro-integracao AS LONGCHAR  NO-UNDO.

{utp/ut-glob.i} 

DEFINE VARIABLE v-retorno   AS LONGCHAR   NO-UNDO.
DEFINE VARIABLE cSourceType AS CHARACTER  NO-UNDO.
DEFINE VARIABLE cReadMode   AS CHARACTER  NO-UNDO INITIAL "EMPTY".
DEFINE VARIABLE hDSet       AS HANDLE     NO-UNDO.
DEFINE VARIABLE httRetorno  AS HANDLE     NO-UNDO.
DEFINE VARIABLE lRetOK      AS LOGICAL    NO-UNDO.
DEFINE VARIABLE client      AS COM-HANDLE NO-UNDO.
DEFINE VARIABLE c-texto     AS  LONGCHAR NO-UNDO.
DEF VAR v-response          AS LONGCHAR NO-UNDO.
//MESSAGE p-url VIEW-AS ALERT-BOX INFORMATION BUTTONS OK TITLE "URL".

CREATE "Msxml2.ServerXMLHTTP.6.0" client no-error.
client:OPEN("post", p-url, FALSE) no-error.
client:setOption(2,"13056") no-error. /*"SXH_SERV_CERT_IGNORE_ALL_SERVER_ERRORS" ignora o erro do certificado*/
client:SetRequestHeader ("Content-Type", "application/XML") no-error.
client:SetRequestHeader ("incluir-resposta-protocolada", "TRUE") no-error    .

client:Send(p-longchar) no-error. 
//MESSAGE STRING(client:ResponseText) VIEW-AS ALERT-BOX INFORMATION BUTTONS OK TITLE 'client:ResponseText'.
//IF client:ResponseText <> "" AND client:ResponseText <>  ? THEN do :
   ASSIGN p-retonro-integracao = IF client:ResponseText <> "" AND client:ResponseText <>  ? then (client:ResponseText) else "" no-error.
          v-retorno            = IF client:ResponseText <> "" AND client:ResponseText <>  ? then (client:ResponseText) else "" no-error.
          v-response           = IF client:ResponseText <> "" AND client:ResponseText <>  ? then (client:ResponseText) else "" no-error.
          p-retonro-integracao  = v-response no-error.

   //MESSAGE STRING(client:ResponseText)  VIEW-AS ALERT-BOX INFORMATION BUTTONS OK TITLE 'client:ResponseText'.
   //MESSAGE string(p-retonro-integracao) VIEW-AS ALERT-BOX INFORMATION BUTTONS OK TITLE "Teste".

END.
ELSE DO:
  ASSIGN c-texto  = "Erro no processo de integracao com a Iventti"
         p-longchar  = c-texto no-error.
END.

//MESSAGE STRING(p-retonro-integracao)VIEW-AS ALERT-BOX INFORMATION BUTTONS OK TITLE 'p-retonro-integracao'.

RELEASE OBJECT client.




