                                                       RUN getSonDec IN hGenXml (INPUT getStack(), INPUT "PostingItemValueFASB", OUTPUT ttPostingItem.PostingItemValueFASB).
                                                       RUN getSonDec IN hGenXml (INPUT getStack(), INPUT "PostingItemValueCMCAC", OUTPUT ttPostingItem.PostingItemValueCMCAC).
                                                       RUN getSonDec IN hGenXml (INPUT getStack(), INPUT "PostingItemPresentValue", OUTPUT ttPostingItem.PostingItemPresentValue).
                                                       RUN getSonDate IN hGenXml (INPUT getStack(), INPUT "PostingItemExchangeDate", OUTPUT ttPostingItem.PostingItemExchangeDate).
                                                       RUN getSonVal IN hGenXml (INPUT getStack(), INPUT "PostingDetail", OUTPUT ttPostingItem.PostingDetail).
                                                       RUN getSonDec IN hGenXml (INPUT getStack(), INPUT "ContraparterPostingSequenceNumber", OUTPUT ttPostingItem.ContraparterPostingSequenceNu_00).
                                                       RUN getSonVal IN hGenXml (INPUT getStack(), INPUT "PostingItemTypeCode", OUTPUT ttPostingItem.PostingItemTypeCode).
                                                       RUN searchTag IN hGenXml (INPUT "GLScenarioInformation", INPUT getStack(), OUTPUT iId).
                                                       if (iId <> ?) THEN DO:
                                                            addStack(iId).

                                                                 RUN getSonVal IN hGenXml (INPUT getStack(), INPUT "ScenarioCode", OUTPUT ttPostingItem.ScenarioCode).
                                                                 RUN getSonVal IN hGenXml (INPUT getStack(), INPUT "ScenarioDescription", OUTPUT ttPostingItem.ScenarioDescription).
                                                            delStack().
                                                       END.

                                                       RUN getSonLog IN hGenXml (INPUT getStack(), INPUT "IsResultRaisePosting", OUTPUT ttPostingItem.IsResultRaisePosting).
                                                       RUN getSonVal IN hGenXml (INPUT getStack(), INPUT "EntryNumber", OUTPUT ttPostingItem.EntryNumber).
                                                       RUN searchTag IN hGenXml (INPUT "ListOfPostingAppropriation", INPUT getStack(), OUTPUT iId).
                                                       if (iId <> ?) THEN DO:
                                                            addStack(iId).

                                                                 RUN getFirstSonId IN hGenXml (INPUT getStack(), OUTPUT iId).

                                                                 DO WHILE iId <> ?:
                                                                 addStack(iId).

                                                                      /*Criacao de valores para manter as relacoes*/
                                                                      CREATE ttPostingAppropriation.
                                                                      ASSIGN ttPostingAppropriation.ttPostingAppropriationID = iId.
                                                                      ASSIGN ttPostingAppropriation.ttPostingItemID = ttPostingItem.ttPostingItemID.

                                                                      RUN getSonDec IN hGenXml (INPUT getStack(), INPUT "PostingAppropriationSequence", OUTPUT ttPostingAppropriation.PostingAppropriationSequence).
                                                                      RUN searchTag IN hGenXml (INPUT "CurrencyInformation", INPUT getStack(), OUTPUT iId).
                                                                      if (iId <> ?) THEN DO:
                                                                           addStack(iId).

                                                                                RUN getSonVal IN hGenXml (INPUT getStack(), INPUT "CurrencyCode", OUTPUT ttPostingAppropriation.CurrencyCode).
                                                                                RUN getSonVal IN hGenXml (INPUT getStack(), INPUT "CurrencyDescription", OUTPUT ttPostingAppropriation.CurrencyDescription).
                                                                           delStack().
                                                                      END.

                                                                      RUN getSonVal IN hGenXml (INPUT getStack(), INPUT "OriginValuePosting", OUTPUT ttPostingAppropriation.OriginValuePosting).
                                                                      RUN getSonDec IN hGenXml (INPUT getStack(), INPUT "PostingAppropriationValue", OUTPUT ttPostingAppropriation.PostingAppropriationValue).
                                                                      RUN searchTag IN hGenXml (INPUT "ExchangeInformation", INPUT getStack(), OUTPUT iId).
                                                                      if (iId <> ?) THEN DO:
                                                                           addStack(iId).

                                                                                RUN getSonDate IN hGenXml (INPUT getStack(), INPUT "ExchangeDate", OUTPUT ttPostingAppropriation.ExchangeDate).
                                                                                RUN getSonDec IN hGenXml (INPUT getStack(), INPUT "ExchangeValue", OUTPUT ttPostingAppropriation.ExchangeValue).
                                                                           delStack().
                                                                      END.

                                                                      ASSIGN iId = getStack().
                                                                      delStack().
                                                                      RUN getNextSonId IN hGenXml (INPUT getStack(), INPUT iId, OUTPUT iId).
                                                                 END.

                                                            delStack().
                                                       END.

                                                       ASSIGN iId = getStack().
                                                       delStack().
                                                       RUN getNextSonId IN hGenXml (INPUT getStack(), INPUT iId, OUTPUT iId).
                                                  END.

                                             delStack().
                                        END.

                                        ASSIGN iId = getStack().
                                        delStack().
                                        RUN getNextSonId IN hGenXml (INPUT getStack(), INPUT iId, OUTPUT iId).
                                   END.

                              delStack().
                         END.

                         ASSIGN iId = getStack().
                         delStack().
                         RUN getNextSonId IN hGenXml (INPUT getStack(), INPUT iId, OUTPUT iId).
                    END.

               delStack().
          END.

     delStack().
     /* ********* LEITURA DA MENSAGEM - END   ********* */


     /* ********* EFETIVAĆŪO - BEGIN ********* */



{adapters\xml\ct5\axrct025Upsert.i}


