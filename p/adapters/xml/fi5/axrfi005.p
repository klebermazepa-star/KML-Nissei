                                                                      RUN getSonVal IN hGenXml (INPUT getStack(), INPUT "AccountDescription", OUTPUT ttPendentTaxInformation.AccountDescription_00).
                                                                      RUN getSonVal IN hGenXml (INPUT getStack(), INPUT "AlternateAccountCode", OUTPUT ttPendentTaxInformation.AlternateAccountCode_00).
                                                                      RUN getSonVal IN hGenXml (INPUT getStack(), INPUT "InternationalStandardAccountCode", OUTPUT ttPendentTaxInformation.InternationalStandardAccountC_00).
                                                                      RUN getSonDec IN hGenXml (INPUT getStack(), INPUT "ReducedAccountCode", OUTPUT ttPendentTaxInformation.ReducedAccountCode_00).
                                                                 delStack().
                                                            END.

                                                            RUN searchTag IN hGenXml (INPUT "ExternalFinancialFlowType", INPUT getStack(), OUTPUT iId).
                                                            if (iId <> ?) THEN DO:
                                                                 addStack(iId).

                                                                      RUN getSonVal IN hGenXml (INPUT getStack(), INPUT "FinancialFlowTypeCode", OUTPUT ttPendentTaxInformation.FinancialFlowTypeCode).
                                                                      RUN getSonVal IN hGenXml (INPUT getStack(), INPUT "FinancialFlowTypeDescription", OUTPUT ttPendentTaxInformation.FinancialFlowTypeDescription).
                                                                 delStack().
                                                            END.

                                                            ASSIGN iId = getStack().
                                                            delStack().
                                                            RUN getNextSonId IN hGenXml (INPUT getStack(), INPUT iId, OUTPUT iId).
                                                       END.

                                                  delStack().
                                             END.

                                             RUN searchTag IN hGenXml (INPUT "ExternalEconomicPurposeInformation", INPUT getStack(), OUTPUT iId).
                                             if (iId <> ?) THEN DO:
                                                  addStack(iId).

                                                       RUN getSonVal IN hGenXml (INPUT getStack(), INPUT "EconomicPurposeCode", OUTPUT ttAccountPayableDocumentI_00.EconomicPurposeCode).
                                                       RUN getSonVal IN hGenXml (INPUT getStack(), INPUT "EconomicPurposeDescription", OUTPUT ttAccountPayableDocumentI_00.EconomicPurposeDescription).
                                                  delStack().
                                             END.

                                             ASSIGN iId = getStack().
                                             delStack().
                                             RUN getNextSonId IN hGenXml (INPUT getStack(), INPUT iId, OUTPUT iId).
                                        END.

                                   delStack().
                              END.

                              RUN searchTag IN hGenXml (INPUT "ListOfRelactoAccountPayableDocument", INPUT getStack(), OUTPUT iId).
                              if (iId <> ?) THEN DO:
                                   addStack(iId).

                                        RUN getFirstSonId IN hGenXml (INPUT getStack(), OUTPUT iId).

                                        DO WHILE iId <> ?:
                                        addStack(iId).

                                             /*Criacao de valores para manter as relacoes*/
                                             CREATE ttRelactoAccountPayableDo_00.
                                             ASSIGN ttRelactoAccountPayableDo_00.ttRelactoAccountPayableDo_00ID = iId.

                                             RUN searchTag IN hGenXml (INPUT "SupplierInformation", INPUT getStack(), OUTPUT iId).
                                             if (iId <> ?) THEN DO:
                                                  addStack(iId).

                                                       RUN getSonVal IN hGenXml (INPUT getStack(), INPUT "SupplierCode", OUTPUT ttRelactoAccountPayableDo_00.SupplierCode).
                                                       RUN getSonVal IN hGenXml (INPUT getStack(), INPUT "SupplierName", OUTPUT ttRelactoAccountPayableDo_00.SupplierName).
                                                       RUN getSonVal IN hGenXml (INPUT getStack(), INPUT "SupplierShortName", OUTPUT ttRelactoAccountPayableDo_00.SupplierShortName).
                                                       RUN getSonVal IN hGenXml (INPUT getStack(), INPUT "GenerealIdentification", OUTPUT ttRelactoAccountPayableDo_00.GenerealIdentification).
                                                       RUN getSonDec IN hGenXml (INPUT getStack(), INPUT "EntityCode", OUTPUT ttRelactoAccountPayableDo_00.EntityCode).
                                                       RUN searchTag IN hGenXml (INPUT "SupplierGroupInformation", INPUT getStack(), OUTPUT iId).
                                                       if (iId <> ?) THEN DO:
                                                            addStack(iId).

                                                                 RUN getSonVal IN hGenXml (INPUT getStack(), INPUT "SupplierGroupCode", OUTPUT ttRelactoAccountPayableDo_00.SupplierGroupCode).
                                                                 RUN getSonVal IN hGenXml (INPUT getStack(), INPUT "SupplierGroupDescription", OUTPUT ttRelactoAccountPayableDo_00.SupplierGroupDescription).
                                                            delStack().
                                                       END.

                                                  delStack().
                                             END.

                                             RUN searchTag IN hGenXml (INPUT "DocumentClassInformation", INPUT getStack(), OUTPUT iId).
                                             if (iId <> ?) THEN DO:
                                                  addStack(iId).

                                                       RUN getSonVal IN hGenXml (INPUT getStack(), INPUT "DocumentClassCode", OUTPUT ttRelactoAccountPayableDo_00.DocumentClassCode).
                                                       RUN getSonVal IN hGenXml (INPUT getStack(), INPUT "DocumentClassDescription", OUTPUT ttRelactoAccountPayableDo_00.DocumentClassDescription).
                                                  delStack().
                                             END.

                                             RUN searchTag IN hGenXml (INPUT "DocumentInformation", INPUT getStack(), OUTPUT iId).
                                             if (iId <> ?) THEN DO:
                                                  addStack(iId).

                                                       RUN getSonVal IN hGenXml (INPUT getStack(), INPUT "DocumentSerieCode", OUTPUT ttRelactoAccountPayableDo_00.DocumentSerieCode).
                                                       RUN getSonVal IN hGenXml (INPUT getStack(), INPUT "DocumentNumber", OUTPUT ttRelactoAccountPayableDo_00.DocumentNumber).
                                                       RUN getSonVal IN hGenXml (INPUT getStack(), INPUT "DocumentParcelNumber", OUTPUT ttRelactoAccountPayableDo_00.DocumentParcelNumber).
                                                  delStack().
                                             END.

                                             RUN searchTag IN hGenXml (INPUT "BranchInformation", INPUT getStack(), OUTPUT iId).
                                             if (iId <> ?) THEN DO:
                                                  addStack(iId).

                                                       RUN getSonVal IN hGenXml (INPUT getStack(), INPUT "BranchCode", OUTPUT ttRelactoAccountPayableDo_00.BranchCode).
                                                       RUN getSonVal IN hGenXml (INPUT getStack(), INPUT "BranchDescription", OUTPUT ttRelactoAccountPayableDo_00.BranchDescription).
                                                  delStack().
                                             END.

                                             RUN getSonVal IN hGenXml (INPUT getStack(), INPUT "CorrectValueReason", OUTPUT ttRelactoAccountPayableDo_00.CorrectValueReason).
                                             ASSIGN iId = getStack().
                                             delStack().
                                             RUN getNextSonId IN hGenXml (INPUT getStack(), INPUT iId, OUTPUT iId).
                                        END.

                                   delStack().
                              END.

                         delStack().
                    END.

                    RUN getSonVal IN hGenXml (INPUT getStack(), INPUT "ExternalOrganizationTranslationMatrixCode", OUTPUT ExternalOrganizationTranslati_00).
               delStack().
          END.

     delStack().
     /* ********* LEITURA DA MENSAGEM - END   ********* */


