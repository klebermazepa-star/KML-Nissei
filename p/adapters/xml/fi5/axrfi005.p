def new global shared var v_cod_arq as char format 'x(60)' no-undo.
def new global shared var v_cod_tip_prog as character format 'x(8)' no-undo.
def stream s-arq.

if  v_cod_arq <> '' and v_cod_arq <> ?
then do:
     run pi_version_extract ('ReplacementAccountPayableDocumentEspecific_506_000Receiver', 'adapters\xml\fi5\axrfi005.p', '001', 'pro').
