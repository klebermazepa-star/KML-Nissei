                                   RUN getSonVal IN hGenXml (INPUT getStack(), INPUT "BranchCode", OUTPUT ttAccountReceivableInform_00.BranchCode).
                                   RUN getSonLog IN hGenXml (INPUT getStack(), INPUT "RestoreCard", OUTPUT ttAccountReceivableInform_00.RestoreCard).
                                   RUN getSonVal IN hGenXml (INPUT getStack(), INPUT "DocumentClassCode", OUTPUT ttAccountReceivableInform_00.DocumentClassCode).
