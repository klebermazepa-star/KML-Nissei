PROCEDURE pi_retornar_finalid_indic_econ:
    /************************ Parameter Definition Begin ************************/
    def Input param p_cod_indic_econ    as CHAR format "x(8)" no-undo.
    def Input param p_dat_transacao     as DATE format "99/99/9999" no-undo.
    def output param p_cod_finalid_econ as CHAR format "x(10)" no-undo.

    /************************* Parameter Definition End *************************/
    for first histor_finalid_econ fields (cod_finalid_econ) no-lock
        where histor_finalid_econ.cod_indic_econ          = p_cod_indic_econ
        and   histor_finalid_econ.dat_inic_valid_finalid <= p_dat_transacao
        and   histor_finalid_econ.dat_fim_valid_finalid  > p_dat_transacao.

        if avail histor_finalid_econ then
           assign p_cod_finalid_econ = histor_finalid_econ.cod_finalid_econ.
    end.
END PROCEDURE. /* pi_retornar_finalid_indic_econ */

procedure pi_grava_erros_api:

    /*****************************************************************************************/
    /** Imprime os erros retornados pela API                                            **/
    /*****************************************************************************************/
    for each tt_log_erros_alter_tit_acr no-lock:

        find first tit_acr where tit_acr.cod_estab = tt_log_erros_alter_tit_acr.tta_cod_estab
                             and tit_acr.num_id_tit_acr = tt_log_erros_alter_tit_acr.tta_num_id_tit_acr
            no-lock no-error.

        assign v_log_control = no.

        create tt_log_erro.
        assign tt_log_erro.ttv_num_cod_erro = tt_log_erros_alter_tit_acr.ttv_num_mensagem
               tt_log_erro.ttv_des_msg_erro = tt_log_erros_alter_tit_acr.ttv_des_msg_erro.

        if  tt_log_erros_alter_tit_acr.ttv_des_msg_ajuda <> "" then
            assign tt_log_erro.ttv_des_msg_erro = tt_log_erro.ttv_des_msg_erro + chr(10) + chr(10) +
                                                  tt_log_erros_alter_tit_acr.ttv_des_msg_ajuda.
        
        find first tit_acr where tit_acr.cod_estab      = tt_log_erros_alter_tit_acr.tta_cod_estab
                             and tit_acr.num_id_tit_acr = tt_log_erros_alter_tit_acr.tta_num_id_tit_acr no-lock no-error.

        if avail tit_acr then do:

            assign v_erro_codigo = tt_log_erros_alter_tit_acr.ttv_num_mensagem
                   v_erro_descri = tt_log_erros_alter_tit_acr.ttv_des_msg_erro
                   v_ajuda       = tt_log_erros_alter_tit_acr.ttv_des_msg_ajuda.

            create tt_erro_implanta.
            assign tt_erro_implanta.tta_cod_erro   = v_erro_codigo
                   tt_erro_implanta.tta_informacao = tit_acr.cod_estab       + "," +
                                                     tit_acr.cod_espec_docto + "," +
                                                     tit_acr.cod_ser_docto   + "," +
                                                     tit_acr.cod_tit_acr     + "," +
                                                     ""                      + "," +
                                                     ""                      + "," +
                                                     ""                      + "," +
                                                     ""                      + "," +
                                                     ""                      + "," +
                                                     ""                      + "," +
                                                     ""                      + "," +
                                                     tit_acr.cod_parcela
                   tt_erro_implanta.tta_des_erro   = v_erro_descri
                   tt_erro_implanta.tta_ajuda      = v_ajuda.

            
        end.
        else do:

            assign v_erro_codigo = tt_log_erros_alter_tit_acr.ttv_num_mensagem
                   v_erro_descri = tt_log_erros_alter_tit_acr.ttv_des_msg_erro
                   v_ajuda       = tt_log_erros_alter_tit_acr.ttv_des_msg_ajuda.

            create tt_erro_implanta.
            assign tt_erro_implanta.tta_cod_erro   = v_erro_codigo
                   tt_erro_implanta.tta_informacao = tt_log_erros_alter_tit_acr.tta_cod_estab               + "," +
                                                     ""                                                     + "," +
                                                     ""                                                     + "," +
                                                     ""                                                     + "," +
                                                     ""                                                     + "," +
                                                     ""                                                     + "," +
                                                     ""                                                     + "," +
                                                     ""                                                     + "," +
                                                     ""                                                     + "," +
                                                     ""                                                     + "," +
                                                     string(tt_log_erros_alter_tit_acr.tta_num_id_tit_acr)  + "," +
                                                     ""
                   tt_erro_implanta.tta_des_erro   = v_erro_descri
                   tt_erro_implanta.tta_ajuda      = v_ajuda.
            

        end.
    end.
end.



