                                   RUN getSonVal IN hGenXml (INPUT getStack(), INPUT "DocumentNumber", OUTPUT ttAccountReceivableInform_00.DocumentNumber).
                                   RUN getSonVal IN hGenXml (INPUT getStack(), INPUT "DocumentParcelNumber", OUTPUT ttAccountReceivableInform_00.DocumentParcelNumber).
                                   RUN getSonVal IN hGenXml (INPUT getStack(), INPUT "ManagerNumber", OUTPUT ttAccountReceivableInform_00.ManagerNumber).
                                   RUN getSonDec IN hGenXml (INPUT getStack(), INPUT "CardSequence", OUTPUT ttAccountReceivableInform_00.CardSequence).
                                   RUN getSonVal IN hGenXml (INPUT getStack(), INPUT "ParcelTotal", OUTPUT ttAccountReceivableInform_00.ParcelTotal).
                                   RUN getSonVal IN hGenXml (INPUT getStack(), INPUT "ProofSell", OUTPUT ttAccountReceivableInform_00.ProofSell).
                                   RUN getSonVal IN hGenXml (INPUT getStack(), INPUT "CardAuthorize", OUTPUT ttAccountReceivableInform_00.CardAuthorize).
                                   RUN getSonDate IN hGenXml (INPUT getStack(), INPUT "DateSell", OUTPUT ttAccountReceivableInform_00.DateSell).
                                   RUN getSonDate IN hGenXml (INPUT getStack(), INPUT "DateCredit", OUTPUT ttAccountReceivableInform_00.DateCredit).
                                   RUN getSonDec IN hGenXml (INPUT getStack(), INPUT "ValueSellProof", OUTPUT ttAccountReceivableInform_00.ValueSellProof).
                                   RUN getSonDec IN hGenXml (INPUT getStack(), INPUT "ValueManagerCard", OUTPUT ttAccountReceivableInform_00.ValueManagerCard).
