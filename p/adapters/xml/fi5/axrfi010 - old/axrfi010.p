                                   RUN getSonVal IN hGenXml (INPUT getStack(), INPUT "ReferCode", OUTPUT ttAccountReceivableInform_00.ReferCode).
                                   ASSIGN iId = getStack().
                                   delStack().
                                   RUN getNextSonId IN hGenXml (INPUT getStack(), INPUT iId, OUTPUT iId).
                              END.

                         delStack().
                    END.

               delStack().
