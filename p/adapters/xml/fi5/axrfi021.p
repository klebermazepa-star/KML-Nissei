PROCEDURE pi_atualiza_cliente:

    CREATE tt_cliente_integr_j.
    ASSIGN tt_cliente_integr_j.ttv_num_tip_operac        = 1.

    FIND ems.cliente NO-LOCK WHERE
        cliente.cod_empresa = v_cod_empres_usuar AND
        cliente.cdn_cliente = CustomerVendorCode NO-ERROR.

    IF  AVAIL cliente THEN
        FIND clien_financ NO-LOCK WHERE
            clien_financ.cod_empresa = cliente.cod_empresa AND
            clien_financ.cdn_cliente = cliente.cdn_cliente NO-ERROR.
    
    
    IF  AVAIL cliente  THEN DO:
             
        ASSIGN tt_cliente_integr_j.tta_cod_empresa           = cliente.cod_empresa
               tt_cliente_integr_j.tta_cdn_cliente           = cliente.cdn_cliente
               tt_cliente_integr_j.tta_num_pessoa            = 0 /*cliente.num_pessoa*/
               tt_cliente_integr_j.tta_nom_abrev             = cliente.nom_abrev
               tt_cliente_integr_j.tta_cod_grp_clien         = cliente.cod_grp_clien
               tt_cliente_integr_j.tta_cod_tip_clien         = cliente.cod_tip_clien
               tt_cliente_integr_j.tta_dat_impl_clien        = cliente.dat_impl_clien
               tt_cliente_integr_j.tta_cod_pais              = cliente.cod_pais
               tt_cliente_integr_j.tta_cod_id_feder          = cliente.cod_id_feder.
    END.
    ELSE
        ASSIGN tt_cliente_integr_j.tta_cdn_cliente = CustomerVendorCode.

    IF tt_cliente_integr_j.tta_cod_empresa = "" THEN 
        ASSIGN tt_cliente_integr_j.tta_cod_empresa = v_cod_empres_usuar.

    IF CustomerVendorShortName <> "" THEN
        ASSIGN tt_cliente_integr_j.tta_nom_abrev   = CustomerVendorShortName.
    

    FIND FIRST ttInformacaoGrupoCliente NO-LOCK NO-ERROR.
    IF AVAIL ttInformacaoGrupoCliente THEN
        ASSIGN tt_cliente_integr_j.tta_cod_grp_clien = IF ttInformacaoGrupoCliente.CustomerGroupCode <> ? THEN ttInformacaoGrupoCliente.CustomerGroupCode 
                                                       ELSE tt_cliente_integr_j.tta_cod_grp_clien.

    FIND FIRST ttInformacaoTipoCliente NO-LOCK NO-ERROR.
    IF AVAIL ttInformacaoTipoCliente THEN
        ASSIGN tt_cliente_integr_j.tta_cod_tip_clien = IF ttInformacaoTipoCliente.CustomerTypeCode <> ? THEN ttInformacaoTipoCliente.CustomerTypeCode 
                                                       ELSE tt_cliente_integr_j.tta_cod_tip_clien.


    ASSIGN tt_cliente_integr_j.tta_dat_impl_clien    = IF DateAdded <> ? THEN DateAdded ELSE IF tt_cliente_integr_j.tta_dat_impl_clien = ? THEN TODAY 
                                                       ELSE tt_cliente_integr_j.tta_dat_impl_clien.


    FIND FIRST ttInformacaoEndCliFornec NO-LOCK NO-ERROR.
    IF AVAIL ttInformacaoEndCliFornec  THEN
        ASSIGN tt_cliente_integr_j.tta_cod_pais      = IF ttInformacaoEndCliFornec.Country <> ? THEN ttInformacaoEndCliFornec.Country 
                                                       ELSE tt_cliente_integr_j.tta_cod_pais.

    FIND FIRST ttInformacaoIDICliFornec NO-LOCK NO-ERROR.
    IF AVAIL ttInformacaoIDICliFornec THEN
        ASSIGN tt_cliente_integr_j.tta_cod_id_feder  = IF ttInformacaoIDICliFornec.TaxID <> ? THEN ttInformacaoIDICliFornec.TaxID 
                                                       ELSE tt_cliente_integr_j.tta_cod_id_feder.

    
    CREATE tt_clien_financ_integr_e.
    ASSIGN tt_clien_financ_integr_e.ttv_num_tip_operac = 1.

    IF  AVAIL clien_financ THEN DO:
        
        ASSIGN tt_clien_financ_integr_e.tta_cod_empresa                 = clien_financ.cod_empresa
               tt_clien_financ_integr_e.tta_cdn_cliente                 = clien_financ.cdn_cliente
               tt_clien_financ_integr_e.tta_cdn_repres                  = clien_financ.cdn_repres
               tt_clien_financ_integr_e.ttv_cod_portad_prefer           = clien_financ.cod_portad_prefer
               tt_clien_financ_integr_e.tta_cod_portador                = clien_financ.cod_portador
               tt_clien_financ_integr_e.tta_cod_cta_corren_bco          = clien_financ.cod_cta_corren_bco
               tt_clien_financ_integr_e.tta_cod_digito_cta_corren       = clien_financ.cod_digito_cta_corren
               tt_clien_financ_integr_e.tta_cod_agenc_bcia              = clien_financ.cod_agenc_bcia
               tt_clien_financ_integr_e.tta_cod_banco                   = clien_financ.cod_banco
               tt_clien_financ_integr_e.tta_cod_classif_msg_cobr        = clien_financ.cod_classif_msg_cobr  
               tt_clien_financ_integr_e.tta_cod_instruc_bcia_1_acr      = clien_financ.cod_instruc_bcia_1_acr
               tt_clien_financ_integr_e.tta_cod_instruc_bcia_2_acr      = clien_financ.cod_instruc_bcia_2_acr
               tt_clien_financ_integr_e.tta_log_habilit_emis_boleto     = clien_financ.log_habilit_emis_boleto
               tt_clien_financ_integr_e.tta_log_habilit_gera_avdeb      = clien_financ.log_habilit_gera_avdeb 
               tt_clien_financ_integr_e.tta_log_retenc_impto            = clien_financ.log_retenc_impto       
               tt_clien_financ_integr_e.tta_log_habilit_db_autom        = clien_financ.log_habilit_db_autom   
               tt_clien_financ_integr_e.tta_num_tit_acr_aber            = clien_financ.num_tit_acr_aber
               tt_clien_financ_integr_e.tta_ind_sit_clien_perda_dedut   = clien_financ.ind_sit_clien_perda_dedut
               tt_clien_financ_integr_e.tta_cod_tip_fluxo_financ        = clien_financ.cod_tip_fluxo_financ
               tt_clien_financ_integr_e.tta_log_utiliz_verba            = clien_financ.log_utiliz_verba
               tt_clien_financ_integr_e.tta_val_perc_verba              = clien_financ.val_perc_verba  
               tt_clien_financ_integr_e.tta_val_min_avdeb               = clien_financ.val_min_avdeb   
               tt_clien_financ_integr_e.tta_log_calc_multa              = clien_financ.log_calc_multa  
               tt_clien_financ_integr_e.tta_num_dias_atraso_avdeb       = clien_financ.num_dias_atraso_avdeb
               tt_clien_financ_integr_e.tta_cod_cart_bcia               = clien_financ.cod_cart_bcia
               tt_clien_financ_integr_e.tta_cod_cart_bcia_prefer        = clien_financ.cod_cart_bcia_prefer.            

    END.
    ELSE DO:
        ASSIGN tt_clien_financ_integr_e.tta_cdn_cliente = IF AVAIL cliente THEN cliente.cdn_cliente ELSE CustomerVendorCode.
    END.
    
    IF tt_clien_financ_integr_e.tta_cod_empresa = "" THEN 
        ASSIGN tt_clien_financ_integr_e.tta_cod_empresa = v_cod_empres_usuar.


    FIND FIRST ttInformacaoRepres NO-LOCK NO-ERROR.
    IF  AVAIL ttInformacaoRepres THEN
        ASSIGN tt_clien_financ_integr_e.tta_cdn_repres = IF ttInformacaoRepres.RepresentativeCode <> ? THEN INTEGER(ttInformacaoRepres.RepresentativeCode) 
                                                         ELSE tt_clien_financ_integr_e.tta_cdn_repres.

     
    FIND FIRST ttInformacaoTipoFluxoFinanc NO-LOCK NO-ERROR.
    IF  AVAIL ttInformacaoTipoFluxoFinanc THEN
        ASSIGN tt_clien_financ_integr_e.tta_cod_tip_fluxo_financ = IF ttInformacaoTipoFluxoFinanc.FinancialFlowTypeCode <> ? THEN 
                                                                   ttInformacaoTipoFluxoFinanc.FinancialFlowTypeCode ELSE
                                                                   tt_clien_financ_integr_e.tta_cod_tip_fluxo_financ.


    FIND FIRST ttInformacaoPortador OF ttInformacaoEspecifCliente  NO-LOCK NO-ERROR.
    IF  AVAIL ttInformacaoPortador THEN
        ASSIGN tt_clien_financ_integr_e.tta_cod_portador           = IF ttInformacaoPortador.CollectorCode <> ? THEN ttInformacaoPortador.CollectorCode 
                                                                     ELSE tt_clien_financ_integr_e.tta_cod_portador
               tt_clien_financ_integr_e.tta_cod_cart_bcia          = IF ttInformacaoPortador.PortfolioCode <> ? THEN ttInformacaoPortador.PortfolioCode 
                                                                     ELSE tt_clien_financ_integr_e.tta_cod_cart_bcia.


    FIND FIRST ttInformacaoPortPreferencial OF ttInformacaoEspecifCliente  NO-LOCK NO-ERROR.
    IF  AVAIL ttInformacaoPortPreferencial THEN
        ASSIGN tt_clien_financ_integr_e.ttv_cod_portad_prefer      = IF ttInformacaoPortPreferencial.CollectorCode_00 <> ? THEN ttInformacaoPortPreferencial.CollectorCode_00
                                                                     ELSE tt_clien_financ_integr_e.ttv_cod_portad_prefer
               tt_clien_financ_integr_e.tta_cod_cart_bcia_prefer   = IF ttInformacaoPortPreferencial.PortfolioCode_00 <> ? THEN ttInformacaoPortPreferencial.PortfolioCode_00
                                                                     ELSE tt_clien_financ_integr_e.tta_cod_cart_bcia_prefer.


    FIND FIRST ttInformacaoBancarias NO-LOCK NO-ERROR.
    IF  AVAIL ttInformacaoBancarias THEN
        ASSIGN tt_clien_financ_integr_e.tta_cod_banco              = IF ttInformacaoBancarias.BankCode <> ? THEN ttInformacaoBancarias.BankCode 
                                                                     ELSE tt_clien_financ_integr_e.tta_cod_banco
               tt_clien_financ_integr_e.tta_cod_cta_corren_bco     = IF ttInformacaoBancarias.CheckingAccountNumber <> ? THEN ttInformacaoBancarias.CheckingAccountNumber 
                                                                     ELSE tt_clien_financ_integr_e.tta_cod_cta_corren_bco
               tt_clien_financ_integr_e.tta_cod_digito_cta_corren  = IF ttInformacaoBancarias.CheckingAccountKey <> ? THEN ttInformacaoBancarias.CheckingAccountKey 
                                                                     ELSE tt_clien_financ_integr_e.tta_cod_digito_cta_corren
               tt_clien_financ_integr_e.tta_cod_agenc_bcia         = IF ttInformacaoBancarias.BranchCode <> ? THEN ttInformacaoBancarias.BranchCode 
                                                                     ELSE tt_clien_financ_integr_e.tta_cod_agenc_bcia
               tt_clien_financ_integr_e.tta_cod_classif_msg_cobr   = IF ttInformacaoBancarias.CollectionMessageClassificati_00 <> ? THEN ttInformacaoBancarias.CollectionMessageClassificati_00
                                                                     ELSE tt_clien_financ_integr_e.tta_cod_classif_msg_cobr
               tt_clien_financ_integr_e.tta_cod_instruc_bcia_1_acr = IF ttInformacaoBancarias.BankInstructionCode1 <> ? THEN ttInformacaoBancarias.BankInstructionCode1
                                                                     ELSE tt_clien_financ_integr_e.tta_cod_instruc_bcia_1_acr
               tt_clien_financ_integr_e.tta_cod_instruc_bcia_2_acr = IF ttInformacaoBancarias.BankInstructionCode2 <> ? THEN ttInformacaoBancarias.BankInstructionCode2
                                                                     ELSE tt_clien_financ_integr_e.tta_cod_instruc_bcia_2_acr.
               

    FIND FIRST ttInformacaoTipoFluxoFinanc NO-LOCK NO-ERROR.
    IF  AVAIL ttInformacaoTipoFluxoFinanc THEN
        ASSIGN tt_clien_financ_integr_e.tta_cod_tip_fluxo_financ = IF ttInformacaoTipoFluxoFinanc.FinancialFlowTypeCode <> ? THEN ttInformacaoTipoFluxoFinanc.FinancialFlowTypeCode
                                                                   ELSE tt_clien_financ_integr_e.tta_cod_tip_fluxo_financ.
    

    FIND FIRST ttInformacaoEspecifCliente NO-LOCK NO-ERROR.
    IF  AVAIL ttInformacaoEspecifCliente THEN
        ASSIGN tt_clien_financ_integr_e.tta_log_habilit_emis_boleto     = IF ttInformacaoEspecifCliente.StatementPrint <> ? THEN ttInformacaoEspecifCliente.StatementPrint
                                                                          ELSE tt_clien_financ_integr_e.tta_log_habilit_emis_boleto
               tt_clien_financ_integr_e.tta_log_habilit_gera_avdeb      = IF ttInformacaoEspecifCliente.GenerateDebitMemo <> ? THEN ttInformacaoEspecifCliente.GenerateDebitMemo
                                                                          ELSE tt_clien_financ_integr_e.tta_log_habilit_gera_avdeb
               tt_clien_financ_integr_e.tta_log_retenc_impto            = IF ttInformacaoEspecifCliente.WithholdTax <> ? THEN ttInformacaoEspecifCliente.WithholdTax
                                                                          ELSE tt_clien_financ_integr_e.tta_log_retenc_impto
               tt_clien_financ_integr_e.tta_log_habilit_db_autom        = IF ttInformacaoEspecifCliente.AutomaticDebit <> ? THEN ttInformacaoEspecifCliente.AutomaticDebit
                                                                          ELSE tt_clien_financ_integr_e.tta_log_habilit_db_autom
               tt_clien_financ_integr_e.tta_num_tit_acr_aber            = IF ttInformacaoEspecifCliente.QuantityOpenDocuments <> ? THEN ttInformacaoEspecifCliente.QuantityOpenDocuments
                                                                          ELSE tt_clien_financ_integr_e.tta_num_tit_acr_aber
               tt_clien_financ_integr_e.tta_ind_sit_clien_perda_dedut   = IF ttInformacaoEspecifCliente.CustomerStatus = 1 THEN "Normal" ELSE
                                                                          IF ttInformacaoEspecifCliente.CustomerStatus = 2 THEN "Falido" ELSE
                                                                          IF ttInformacaoEspecifCliente.CustomerStatus = 3 THEN "Concordatario" ELSE
                                                                          IF ttInformacaoEspecifCliente.CustomerStatus = 4 THEN "Insolvencia Declarada"
                                                                          ELSE tt_clien_financ_integr_e.tta_ind_sit_clien_perda_dedut
               tt_clien_financ_integr_e.tta_log_neces_acompto_spc       = IF ttInformacaoEspecifCliente.CRServiceRequirement <> ? THEN ttInformacaoEspecifCliente.CRServiceRequirement
                                                                          ELSE tt_clien_financ_integr_e.tta_log_neces_acompto_spc
               tt_clien_financ_integr_e.tta_log_utiliz_verba            = IF ttInformacaoEspecifCliente.UsePublicityAmount <> ? THEN ttInformacaoEspecifCliente.UsePublicityAmount
                                                                          ELSE tt_clien_financ_integr_e.tta_log_utiliz_verba
               tt_clien_financ_integr_e.tta_val_perc_verba              = IF ttInformacaoEspecifCliente.PublicityAmountPercentage <> ? THEN ttInformacaoEspecifCliente.PublicityAmountPercentage
                                                                          ELSE tt_clien_financ_integr_e.tta_val_perc_verba
               tt_clien_financ_integr_e.tta_val_min_avdeb               = IF ttInformacaoEspecifCliente.MinimumAmount <> ? THEN ttInformacaoEspecifCliente.MinimumAmount            
                                                                          ELSE tt_clien_financ_integr_e.tta_val_min_avdeb
               tt_clien_financ_integr_e.tta_log_calc_multa              = IF ttInformacaoEspecifCliente.PenaltyCalculation <> ? THEN ttInformacaoEspecifCliente.PenaltyCalculation       
                                                                          ELSE tt_clien_financ_integr_e.tta_log_calc_multa
               tt_clien_financ_integr_e.tta_num_dias_atraso_avdeb       = IF ttInformacaoEspecifCliente.DaysLate <> ? THEN ttInformacaoEspecifCliente.DaysLate
                                                                          ELSE tt_clien_financ_integr_e.tta_num_dias_atraso_avdeb. 


    RUN pi_atualiza_histor_clien.

    RUN pi_atualiza_contatos.

    /*Valores possiveis= 1- Fisica  2- Juridica)*/
    IF  EntityType = 1 THEN DO:
        ASSIGN tt_cliente_integr_j.ttv_ind_pessoa          = "2" /* FĪsica neste campo é 2 */
               tt_cliente_integr_j.ttv_ind_tip_pessoa_ems2 = "1".
        RUN pi_atualiza_pessoa_fisica.
    END.
    ELSE DO:
        ASSIGN tt_cliente_integr_j.ttv_ind_pessoa          = "1" /* JurĪdica neste campo é 1 */
               tt_cliente_integr_j.ttv_ind_tip_pessoa_ems2 = "2".
        RUN pi_atualiza_pessoa_juridica.
    END.
        
END.

PROCEDURE pi_atualiza_fornecedor:

    FIND FIRST ems.fornecedor NO-LOCK WHERE
        fornecedor.cod_empresa    = v_cod_empres_usuar AND
        fornecedor.cdn_fornecedor = CustomerVendorCode NO-ERROR.

    IF  AVAIL fornecedor THEN
        FIND fornec_financ NO-LOCK WHERE
            fornec_financ.cod_empresa    = fornecedor.cod_empresa AND
            fornec_financ.cdn_fornecedor = fornecedor.cdn_fornecedor NO-ERROR.

    CREATE tt_fornecedor_integr_k.
    ASSIGN tt_fornecedor_integr_k.ttv_num_tip_operac         = 1.

    IF AVAIL fornecedor THEN DO:

        ASSIGN tt_fornecedor_integr_k.tta_cod_empresa            = fornecedor.cod_empresa           
               tt_fornecedor_integr_k.tta_cdn_fornecedor         = fornecedor.cdn_fornecedor        
               tt_fornecedor_integr_k.tta_num_pessoa             = 0 /*fornecedor.num_pessoa            */
               tt_fornecedor_integr_k.tta_nom_abrev              = fornecedor.nom_abrev             
               tt_fornecedor_integr_k.tta_cod_grp_fornec         = fornecedor.cod_grp_fornec        
               tt_fornecedor_integr_k.tta_cod_tip_fornec         = fornecedor.cod_tip_fornec        
               tt_fornecedor_integr_k.tta_dat_impl_fornec        = fornecedor.dat_impl_fornec       
               tt_fornecedor_integr_k.tta_cod_pais               = fornecedor.cod_pais              
               tt_fornecedor_integr_k.tta_cod_id_feder           = fornecedor.cod_id_feder          
               tt_fornecedor_integr_k.tta_log_ems_20_atlzdo      = fornecedor.log_ems_20_atlzdo .

       &if "{&emsfin_version}" >= "5.06" &then
            ASSIGN tt_fornecedor_integr_k.tta_log_cr_pis             = fornecedor.log_cr_pis
                   tt_fornecedor_integr_k.tta_log_cr_cofins          = fornecedor.log_cr_cofins
                   tt_fornecedor_integr_k.tta_log_control_inss       = fornecedor.log_control_inss      
                   tt_fornecedor_integr_k.tta_log_retenc_impto_pagto = fornecedor.log_retenc_impto_pagto.

       &else
            ASSIGN tt_fornecedor_integr_k.tta_log_cr_pis         = fornecedor.log_livre_1
                   tt_fornecedor_integr_k.tta_log_cr_cofins      = IF fornecedor.num_livre_1 = 1 THEN YES ELSE NO.

            IF  NUM-ENTRIES(fornecedor.cod_livre_1) >= 1 THEN
                ASSIGN tt_fornecedor_integr_k.tta_log_control_inss = LOGICAL(ENTRY(1, fornecedor.cod_livre_1, CHR(10))).

            IF  NUM-ENTRIES(fornecedor.cod_livre_1) >= 2 THEN
                ASSIGN tt_fornecedor_integr_k.tta_log_retenc_impto_pagto = LOGICAL(ENTRY(2, fornecedor.cod_livre_1, CHR(10))).
       &endif
    END.
    ELSE
        ASSIGN tt_fornecedor_integr_k.tta_cdn_fornecedor = CustomerVendorCode.

    ASSIGN tt_fornecedor_integr_k.tta_cod_empresa = v_cod_empres_usuar.

    IF CustomerVendorShortName <> "" THEN
        ASSIGN tt_fornecedor_integr_k.tta_nom_abrev    = CustomerVendorShortName.

    FIND FIRST ttInformacaoGrupoFornec NO-LOCK NO-ERROR.
    IF AVAIL ttInformacaoGrupoFornec THEN
        ASSIGN tt_fornecedor_integr_k.tta_cod_grp_fornec = ttInformacaoGrupoFornec.VendorGroupCode.

    FIND FIRST ttInformacaoTipofornec NO-LOCK NO-ERROR.
    IF AVAIL ttInformacaoTipoFornec THEN
        ASSIGN tt_fornecedor_integr_k.tta_cod_tip_fornec = ttInformacaoTipoFornec.VendorTypeCode.

    ASSIGN tt_fornecedor_integr_k.tta_dat_impl_fornec    = IF DateAdded <> ? THEN DateAdded ELSE IF tt_fornecedor_integr_k.tta_dat_impl_fornec = ? THEN TODAY 
                                                       ELSE tt_fornecedor_integr_k.tta_dat_impl_fornec.

    FIND FIRST ttInformacaoEndCliFornec NO-LOCK NO-ERROR.
    IF AVAIL ttInformacaoEndCliFornec  THEN
        ASSIGN tt_fornecedor_integr_k.tta_cod_pais   = ttInformacaoEndCliFornec.Country.

    FIND FIRST ttInformacaoIDICliFornec NO-LOCK NO-ERROR.
    IF AVAIL ttInformacaoIDICliFornec THEN
        ASSIGN tt_fornecedor_integr_k.tta_cod_id_feder  = ttInformacaoIDICliFornec.TaxID.

    FIND FIRST ttInformacaoEspecifFornec NO-LOCK NO-ERROR.
    
    IF AVAIL ttInformacaoEspecifFornec THEN
        ASSIGN tt_fornecedor_integr_k.tta_log_cr_pis             = IF ttInformacaoEspecifFornec.CreditTaxPIS = ? THEN tt_fornecedor_integr_k.tta_log_cr_pis ELSE ttInformacaoEspecifFornec.CreditTaxPIS
               tt_fornecedor_integr_k.tta_log_cr_cofins          = IF ttInformacaoEspecifFornec.CreditTaxCOFINS = ? THEN tt_fornecedor_integr_k.tta_log_cr_cofins ELSE ttInformacaoEspecifFornec.CreditTaxCOFINS
               tt_fornecedor_integr_k.tta_log_control_inss       = IF ttInformacaoEspecifFornec.ControlSSMaximumAmount = ? THEN tt_fornecedor_integr_k.tta_log_control_inss ELSE ttInformacaoEspecifFornec.ControlSSMaximumAmount
               /*tt_fornecedor_integr_k.tta_log_retenc_impto_pagto = ttInformacaoEspecifFornec.log_retenc_impto_pagto*/.


    CREATE tt_fornec_financ_integr_d.
    ASSIGN tt_fornec_financ_integr_d.ttv_num_tip_operac      = 1.

    IF AVAIL fornec_financ THEN DO:

        ASSIGN tt_fornec_financ_integr_d.tta_cod_empresa                    = fornec_financ.cod_empresa              
               tt_fornec_financ_integr_d.tta_cdn_fornecedor                 = fornec_financ.cdn_fornecedor
               tt_fornec_financ_integr_d.tta_cod_portador                   = fornec_financ.cod_portador             
               tt_fornec_financ_integr_d.tta_cod_cta_corren_bco             = fornec_financ.cod_cta_corren_bco       
               tt_fornec_financ_integr_d.tta_cod_digito_cta_corren          = fornec_financ.cod_digito_cta_corren    
               tt_fornec_financ_integr_d.tta_cod_agenc_bcia                 = fornec_financ.cod_agenc_bcia           
               tt_fornec_financ_integr_d.tta_cod_digito_agenc_bcia          = fornec_financ.cod_digito_agenc_bcia
               tt_fornec_financ_integr_d.tta_cod_banco                      = fornec_financ.cod_banco
               tt_fornec_financ_integr_d.tta_cod_forma_pagto                = fornec_financ.cod_forma_pagto
               tt_fornec_financ_integr_d.tta_cod_tip_fluxo_financ           = fornec_financ.cod_tip_fluxo_financ     
               tt_fornec_financ_integr_d.tta_ind_tratam_vencto_sab          = fornec_financ.ind_tratam_vencto_sab    
               tt_fornec_financ_integr_d.tta_ind_tratam_vencto_dom          = fornec_financ.ind_tratam_vencto_dom    
               tt_fornec_financ_integr_d.tta_ind_tratam_vencto_fer          = fornec_financ.ind_tratam_vencto_fer    
               tt_fornec_financ_integr_d.tta_ind_pagto_juros_fornec_ap      = fornec_financ.ind_pagto_juros_fornec_ap
               tt_fornec_financ_integr_d.tta_ind_tip_fornecto               = fornec_financ.ind_tip_fornecto
               tt_fornec_financ_integr_d.tta_ind_armaz_val_pagto            = fornec_financ.ind_armaz_val_pagto      
               tt_fornec_financ_integr_d.tta_log_fornec_serv_export         = fornec_financ.log_fornec_serv_export   
               tt_fornec_financ_integr_d.tta_log_pagto_bloqdo               = fornec_financ.log_pagto_bloqdo         
               tt_fornec_financ_integr_d.tta_log_retenc_impto               = fornec_financ.log_retenc_impto         
               tt_fornec_financ_integr_d.tta_dat_ult_impl_tit_ap            = fornec_financ.dat_ult_impl_tit_ap      
               tt_fornec_financ_integr_d.tta_dat_ult_pagto                  = fornec_financ.dat_ult_pagto            
               tt_fornec_financ_integr_d.tta_dat_impl_maior_tit_ap          = fornec_financ.dat_impl_maior_tit_ap    
               tt_fornec_financ_integr_d.tta_num_antecip_aber               = fornec_financ.num_antecip_aber         
               tt_fornec_financ_integr_d.tta_num_tit_ap_aber                = fornec_financ.num_tit_ap_aber          
               tt_fornec_financ_integr_d.tta_val_tit_ap_maior_val           = fornec_financ.val_tit_ap_maior_val     
               tt_fornec_financ_integr_d.tta_val_tit_ap_maior_val_aber      = fornec_financ.val_tit_ap_maior_val_aber
               tt_fornec_financ_integr_d.tta_val_sdo_antecip_aber           = fornec_financ.val_sdo_antecip_aber     
               tt_fornec_financ_integr_d.tta_val_sdo_tit_ap_aber            = fornec_financ.val_sdo_tit_ap_aber      
               tt_fornec_financ_integr_d.tta_cod_livre_1                    = fornec_financ.cod_livre_1              
               tt_fornec_financ_integr_d.tta_num_rendto_tribut              = fornec_financ.num_rendto_tribut        
               tt_fornec_financ_integr_d.tta_log_vencto_dia_nao_util        = fornec_financ.log_vencto_dia_nao_util  
               tt_fornec_financ_integr_d.tta_val_percent_bonif              = fornec_financ.val_percent_bonif        
               tt_fornec_financ_integr_d.tta_log_indic_rendto               = fornec_financ.log_indic_rendto         
               tt_fornec_financ_integr_d.tta_num_dias_compcao               = fornec_financ.num_dias_compcao. 
    END.
    ELSE DO:
        ASSIGN tt_fornec_financ_integr_d.tta_cdn_fornec = IF AVAIL fornecedor THEN fornecedor.cdn_fornec ELSE CustomerVendorCode.
    END.

    IF tt_fornec_financ_integr_d.tta_cod_empresa = "" THEN 
        ASSIGN tt_fornec_financ_integr_d.tta_cod_empresa = v_cod_empres_usuar.

    FIND FIRST ttInformacaoPortFornec NO-ERROR.
    IF AVAIL ttInformacaoPortFornec THEN DO:
        ASSIGN tt_fornec_financ_integr_d.tta_cod_portador = ttInformacaoPortFornec.CollectorCode.
    END.

    FIND FIRST ttInformacaoEspecifFornec NO-LOCK NO-ERROR.
    IF AVAIL ttInformacaoEspecifFornec THEN
        ASSIGN tt_fornec_financ_integr_d.tta_num_dias_compcao               = ttInformacaoEspecifFornec.ClearanceDays
               tt_fornec_financ_integr_d.tta_val_percent_bonif              = ttInformacaoEspecifFornec.DiscountPercentage
               tt_fornec_financ_integr_d.tta_log_vencto_dia_nao_util        = ttInformacaoEspecifFornec.DueEqualFlowDate
               tt_fornec_financ_integr_d.tta_ind_tratam_vencto_sab          = IF ttInformacaoEspecifFornec.DueSaturday = 1 THEN "Prorroga" ELSE 
                                                                              IF ttInformacaoEspecifFornec.DueSaturday = 2 THEN "Antecipa" ELSE 
                                                                              IF ttInformacaoEspecifFornec.DueSaturday = 3 THEN "Mantem"   ELSE 
                                                                                 tt_fornec_financ_integr_d.tta_ind_tratam_vencto_sab
               tt_fornec_financ_integr_d.tta_ind_tratam_vencto_dom          = IF ttInformacaoEspecifFornec.DueSunday = 1   THEN "Prorroga" ELSE 
                                                                              IF ttInformacaoEspecifFornec.DueSunday = 2   THEN "Antecipa" ELSE 
                                                                              IF ttInformacaoEspecifFornec.DueSunday = 3   THEN "Mantem"   ELSE 
                                                                                 tt_fornec_financ_integr_d.tta_ind_tratam_vencto_dom
               tt_fornec_financ_integr_d.tta_ind_tratam_vencto_fer          = IF ttInformacaoEspecifFornec.DueHoliday = 1  THEN "Prorroga" ELSE 
                                                                              IF ttInformacaoEspecifFornec.DueHoliday = 2  THEN "Antecipa" ELSE 
                                                                              IF ttInformacaoEspecifFornec.DueHoliday = 3  THEN "Mantem"   ELSE 
                                                                                 tt_fornec_financ_integr_d.tta_ind_tratam_vencto_fer
               tt_fornec_financ_integr_d.tta_log_fornec_serv_export         = ttInformacaoEspecifFornec.ExportVendor
               tt_fornec_financ_integr_d.tta_dat_impl_maior_tit_ap          = ttInformacaoEspecifFornec.GreatestAmountDocumentAdditio_00
               tt_fornec_financ_integr_d.tta_log_pagto_bloqdo               = ttInformacaoEspecifFornec.HoldPayment
               tt_fornec_financ_integr_d.tta_ind_pagto_juros_fornec_ap      = IF ttInformacaoEspecifFornec.InsterestPayment = 1 THEN "Pago" ELSE 
                                                                              IF ttInformacaoEspecifFornec.InsterestPayment = 2 THEN "Nao Pago" 
                                                                              ELSE tt_fornec_financ_integr_d.tta_ind_pagto_juros_fornec_ap
               tt_fornec_financ_integr_d.tta_dat_ult_impl_tit_ap            = ttInformacaoEspecifFornec.LastAdditionDocumentDate
               tt_fornec_financ_integr_d.tta_dat_ult_pagto                  = ttInformacaoEspecifFornec.LastPaymentDate
               tt_fornec_financ_integr_d.tta_num_tit_ap_aber                = ttInformacaoEspecifFornec.OpenDocumentQuantity
               tt_fornec_financ_integr_d.tta_num_antecip_aber               = ttInformacaoEspecifFornec.OpenPrepaymentQuantity
               tt_fornec_financ_integr_d.tta_cod_forma_pagto                = IF ttInformacaoEspecifFornec.PaymentType = ? THEN tt_fornec_financ_integr_d.tta_cod_forma_pagto ELSE ttInformacaoEspecifFornec.PaymentType
               tt_fornec_financ_integr_d.tta_log_indic_rendto               = ttInformacaoEspecifFornec.Revenue
               tt_fornec_financ_integr_d.tta_ind_armaz_val_pagto            = IF ttInformacaoEspecifFornec.StorePaymentAmount = 1 THEN "Implantacao" ELSE 
                                                                              IF ttInformacaoEspecifFornec.StorePaymentAmount = 2 THEN "Pagamento"   ELSE
                                                                              IF ttInformacaoEspecifFornec.StorePaymentAmount = 3 THEN "Nao Armazena" 
                                                                              ELSE tt_fornec_financ_integr_d.tta_ind_armaz_val_pagto
               tt_fornec_financ_integr_d.tta_num_rendto_tribut              = ttInformacaoEspecifFornec.TaxableRevenue
               tt_fornec_financ_integr_d.tta_ind_tip_fornecto               = IF ttInformacaoEspecifFornec.VendorType = 1 THEN "Produtos" ELSE
                                                                              IF ttInformacaoEspecifFornec.VendorType = 2 THEN "Servicos" ELSE
                                                                              IF ttInformacaoEspecifFornec.VendorType = 3 THEN "Ambos"    ELSE
                                                                                  tt_fornec_financ_integr_d.tta_ind_tip_fornecto.


    
    RUN pi_atualiza_histor_fornec.

    RUN pi_atualiza_contatos.

    /*Valores possiveis= 1- Fisica  2- Juridica)*/
    IF  EntityType = 1 THEN DO:
        ASSIGN tt_fornecedor_integr_k.ttv_ind_pessoa          = "2" /* FĪsica neste campo é 2 */
               tt_fornecedor_integr_k.ttv_ind_tip_pessoa_ems2 = "1".
        RUN pi_atualiza_pessoa_fisica.
    END.
    ELSE DO:
        ASSIGN tt_fornecedor_integr_k.ttv_ind_pessoa          = "1" /* JurĪdica neste campo é 1 */
               tt_fornecedor_integr_k.ttv_ind_tip_pessoa_ems2 = "2".
        RUN pi_atualiza_pessoa_juridica.
    END.

END.

PROCEDURE pi_atualiza_ambos.

    RUN pi_atualiza_cliente.
    RUN pi_atualiza_fornecedor.
    
END.


PROCEDURE pi_atualiza_pessoa_fisica:

    IF CAN-FIND(FIRST tt_pessoa_fisic_integr_e) THEN RETURN.

    CREATE tt_pessoa_fisic_integr_e.
    ASSIGN tt_pessoa_fisic_integr_e.ttv_num_tip_operac = 1
           tt_pessoa_fisic_integr_e.ttv_log_altera_razao_social = YES.

    IF AVAIL ems.cliente THEN DO:
        FIND pessoa_fisic NO-LOCK WHERE
             pessoa_fisic.num_pessoa_fisic =  cliente.num_pessoa NO-ERROR.
    END.
    ELSE IF AVAIL ems.fornecedor THEN DO:
        FIND pessoa_fisic NO-LOCK WHERE
             pessoa_fisic.num_pessoa_fisic =  fornecedor.num_pessoa NO-ERROR.
    END.
    ELSE DO:
        FIND pessoa_fisic NO-LOCK WHERE
             pessoa_fisic.num_pessoa_fisic =  EntityCode NO-ERROR.
    END.
    IF  AVAIL pessoa_fisic THEN DO:

        ASSIGN tt_pessoa_fisic_integr_e.tta_cod_telefone                 =  pessoa_fisic.cod_telefone
               tt_pessoa_fisic_integr_e.tta_cod_fax                      =  pessoa_fisic.cod_fax                    
               tt_pessoa_fisic_integr_e.tta_cod_ramal_fax                =  pessoa_fisic.cod_ramal_fax              
               tt_pessoa_fisic_integr_e.tta_nom_home_page                =  pessoa_fisic.nom_home_page              
               tt_pessoa_fisic_integr_e.tta_cod_telex                    =  pessoa_fisic.cod_telex                  
               tt_pessoa_fisic_integr_e.tta_cod_modem                    =  pessoa_fisic.cod_modem
               tt_pessoa_fisic_integr_e.tta_cod_ramal_modem              =  pessoa_fisic.cod_ramal_modem
               tt_pessoa_fisic_integr_e.tta_cod_e_mail                   =  pessoa_fisic.cod_e_mail
               tt_pessoa_fisic_integr_e.tta_cod_id_feder                 =  pessoa_fisic.cod_id_feder
               tt_pessoa_fisic_integr_e.tta_cod_id_estad_fisic           =  pessoa_fisic.cod_id_estad_fisic
               tt_pessoa_fisic_integr_e.tta_cod_unid_federac_emis_estad  =  pessoa_fisic.cod_unid_federac_emis_estad
               tt_pessoa_fisic_integr_e.tta_cod_orgao_emis_id_estad      =  pessoa_fisic.cod_orgao_emis_id_estad
               tt_pessoa_fisic_integr_e.tta_dat_nasc_pessoa_fisic        =  pessoa_fisic.dat_nasc_pessoa_fisic
               tt_pessoa_fisic_integr_e.ttv_cod_pais_nasc                =  pessoa_fisic.cod_pais_nasc
               tt_pessoa_fisic_integr_e.tta_des_anot_tab                 =  pessoa_fisic.des_anot_tab
               tt_pessoa_fisic_integr_e.tta_nom_mae_pessoa               =  pessoa_fisic.nom_mae_pessoa
               tt_pessoa_fisic_integr_e.tta_nom_nacion_pessoa_fisic      =  pessoa_fisic.nom_nacion_pessoa_fisic
               tt_pessoa_fisic_integr_e.tta_nom_profis_pessoa_fisic      =  pessoa_fisic.nom_profis_pessoa_fisic
               tt_pessoa_fisic_integr_e.tta_ind_estado_civil_pessoa      =  pessoa_fisic.ind_estado_civil_pessoa
               tt_pessoa_fisic_integr_e.tta_nom_ender_text               =  pessoa_fisic.nom_ender_text.

        /* Begin_Include: i_atualizar_pessoa_fisic */
        &if '{&emsfin_version}' >= '5.07' &then
            assign tt_pessoa_fisic_integr_e.tta_num_pessoa_fisic_cobr = pessoa_fisic.num_pessoa_jurid_cobr 
                   v_cod_pais_cobr                                    = pessoa_fisic.cod_pais_cobr         
                   tt_pessoa_fisic_integr_e.tta_cod_unid_federac_cobr = pessoa_fisic.cod_unid_federac_cobr 
                   tt_pessoa_fisic_integr_e.tta_nom_ender_cobr        = pessoa_fisic.nom_ender_cobr        
                   tt_pessoa_fisic_integr_e.tta_nom_ender_pagto       = pessoa_fisic.nom_ender_cobr_text   
                   tt_pessoa_fisic_integr_e.tta_nom_ender_compl_cobr  = pessoa_fisic.nom_ender_compl_cobr  
                   tt_pessoa_fisic_integr_e.tta_nom_bairro_cobr       = pessoa_fisic.nom_bairro_cobr       
                   tt_pessoa_fisic_integr_e.tta_cod_cep_cobr          = pessoa_fisic.cod_cep_cobr          
                   tt_pessoa_fisic_integr_e.tta_nom_cidad_cobr        = pessoa_fisic.nom_cidad_cobr        
                   tt_pessoa_fisic_integr_e.tta_nom_condad_cobr       = pessoa_fisic.nom_condad_cobr       
                   tt_pessoa_fisic_integr_e.tta_cod_cx_post_cobr      = pessoa_fisic.cod_cx_post_cobr      
                   tt_pessoa_fisic_integr_e.tta_cod_e_mail_cobr.      = pessoa_fisic.cod_email_cobr.

            
        &else
            FIND first tab_livre_emsuni NO-LOCK
               where tab_livre_emsuni.cod_modul_dtsul      = "utb" /*l_utb*/ 
                 and tab_livre_emsuni.cod_tab_dic_dtsul    = 'pessoa_fisic':U
                 and tab_livre_emsuni.cod_compon_2_idx_tab = string(pessoa_fisic.num_pessoa_fisic) NO-ERROR.

            IF AVAIL tab_livre_emsuni THEN do:

                ASSIGN tt_pessoa_fisic_integr_e.tta_num_pessoa_fisic_cobr = INTEGER(ENTRY(1, tab_livre_emsuni.cod_livre_1, CHR(10)))
                       tt_pessoa_fisic_integr_e.tta_cod_unid_federac_cobr = ENTRY(3, tab_livre_emsuni.cod_livre_1, CHR(10))
                       tt_pessoa_fisic_integr_e.tta_nom_ender_cobr        = ENTRY(4, tab_livre_emsuni.cod_livre_1, CHR(10))
                       tt_pessoa_fisic_integr_e.tta_nom_ender_pagto       = ENTRY(5, tab_livre_emsuni.cod_livre_1, CHR(10))
                       tt_pessoa_fisic_integr_e.tta_nom_ender_compl_cobr  = ENTRY(6, tab_livre_emsuni.cod_livre_1, CHR(10))
                       tt_pessoa_fisic_integr_e.tta_nom_bairro_cobr       = ENTRY(7, tab_livre_emsuni.cod_livre_1, CHR(10))
                       tt_pessoa_fisic_integr_e.tta_cod_cep_cobr          = ENTRY(8, tab_livre_emsuni.cod_livre_1, CHR(10))
                       tt_pessoa_fisic_integr_e.tta_nom_cidad_cobr        = ENTRY(9, tab_livre_emsuni.cod_livre_1, CHR(10))
                       tt_pessoa_fisic_integr_e.tta_nom_condad_cobr       = ENTRY(10, tab_livre_emsuni.cod_livre_1, CHR(10))
                       tt_pessoa_fisic_integr_e.tta_cod_cx_post_cobr      = ENTRY(11, tab_livre_emsuni.cod_livre_1, CHR(10))
                       tt_pessoa_fisic_integr_e.tta_cod_e_mail_cobr       = ENTRY(12, tab_livre_emsuni.cod_livre_1, CHR(10)).                    
            END.                       
        &endif

        ASSIGN SUBSTRING(tt_pessoa_fisic_integr_e.tta_nom_ender_text,1991,09) = STRING(CustomerVendorCode).

    END.

    IF CustomerVendorIdentification = 1 THEN DO:
        IF CAN-FIND(FIRST fornecedor WHERE fornecedor.cdn_fornec = CustomerVendorCode) THEN
            ASSIGN SUBSTRING(tt_pessoa_fisic_integr_e.tta_nom_ender_text,1991,09) = STRING(CustomerVendorCode).
    END.

    IF CustomerVendorIdentification = 2 THEN DO:
        IF CAN-FIND(FIRST cliente WHERE cliente.cdn_cliente = CustomerVendorCode) THEN
            ASSIGN SUBSTRING(tt_pessoa_fisic_integr_e.tta_nom_ender_text,1991,09) = STRING(CustomerVendorCode).
    END.

    IF tt_pessoa_fisic_integr_e.tta_cod_pais = "" THEN DO:
        IF (CustomerVendorIdentification = 1 OR
            CustomerVendorIdentification = 3) AND AVAIL tt_cliente_integr_j THEN DO:
            ASSIGN tt_pessoa_fisic_integr_e.tta_cod_pais = tt_cliente_integr_j.tta_cod_pais.
        END.

        IF (CustomerVendorIdentification = 2 OR
            CustomerVendorIdentification = 3) AND AVAIL tt_fornecedor_integr_k THEN DO:
            ASSIGN tt_pessoa_fisic_integr_e.tta_cod_pais = tt_fornecedor_integr_k.tta_cod_pais.
        END.
    END.

    IF tt_pessoa_fisic_integr_e.tta_cod_unid_federac = "" THEN
        ASSIGN tt_pessoa_fisic_integr_e.tta_cod_unid_federac = ttInformacaoEndCliFornec.State.

    IF tt_pessoa_fisic_integr_e.tta_cod_cep = "" THEN
        ASSIGN tt_pessoa_fisic_integr_e.tta_cod_cep = ttInformacaoEndCliFornec.Zip.

    IF tt_pessoa_fisic_integr_e.tta_nom_endereco = "" THEN
        ASSIGN tt_pessoa_fisic_integr_e.tta_nom_endereco = ttInformacaoEndCliFornec.Address.

    IF tt_pessoa_fisic_integr_e.tta_nom_cidade = "" THEN
        ASSIGN tt_pessoa_fisic_integr_e.tta_nom_cidade = ttInformacaoEndCliFornec.City.

    ASSIGN tt_pessoa_fisic_integr_e.tta_cod_imagem = IF IMAGE <> ? THEN IMAGE ELSE tt_pessoa_fisic_integr_e.tta_cod_imagem.

    FIND FIRST ttInformacaoComunicCliFornec NO-LOCK NO-ERROR.
    IF AVAIL ttInformacaoComunicCliFornec THEN
       ASSIGN tt_pessoa_fisic_integr_e.tta_cod_telefone       = IF ttInformacaoComunicCliFornec.PhoneNumber1 <> ? THEN ttInformacaoComunicCliFornec.PhoneNumber1
                                                                ELSE tt_pessoa_fisic_integr_e.tta_cod_telefone
              tt_pessoa_fisic_integr_e.tta_cod_fax            = IF ttInformacaoComunicCliFornec.FaxNumber <> ? THEN ttInformacaoComunicCliFornec.FaxNumber
                                                                ELSE tt_pessoa_fisic_integr_e.tta_cod_fax
              tt_pessoa_fisic_integr_e.tta_cod_ramal_fax      = IF ttInformacaoComunicCliFornec.FaxExtention <> ? THEN ttInformacaoComunicCliFornec.FaxExtention
                                                                ELSE tt_pessoa_fisic_integr_e.tta_cod_ramal_fax
              tt_pessoa_fisic_integr_e.tta_nom_home_page      = IF ttInformacaoComunicCliFornec.HomePage <> ? THEN ttInformacaoComunicCliFornec.HomePage
                                                                ELSE tt_pessoa_fisic_integr_e.tta_nom_home_page
              tt_pessoa_fisic_integr_e.tta_cod_telex          = IF ttInformacaoComunicCliFornec.TelexNumber <> ? THEN ttInformacaoComunicCliFornec.TelexNumber
                                                                ELSE tt_pessoa_fisic_integr_e.tta_cod_telex
              tt_pessoa_fisic_integr_e.tta_cod_modem          = IF ttInformacaoComunicCliFornec.ModemNumber <> ? THEN ttInformacaoComunicCliFornec.ModemNumber
                                                                ELSE tt_pessoa_fisic_integr_e.tta_cod_modem
              tt_pessoa_fisic_integr_e.tta_cod_ramal_modem    = IF ttInformacaoComunicCliFornec.ModemExtention <> ? THEN ttInformacaoComunicCliFornec.ModemExtention
                                                                ELSE tt_pessoa_fisic_integr_e.tta_cod_ramal_modem
              tt_pessoa_fisic_integr_e.tta_cod_e_mail         = IF ttInformacaoComunicCliFornec.EMail <> ? THEN ttInformacaoComunicCliFornec.EMail
                                                                ELSE tt_pessoa_fisic_integr_e.tta_cod_e_mail.

    FIND FIRST ttInformacaoIDICliFornec NO-LOCK NO-ERROR.
    IF  AVAIL ttInformacaoIDICliFornec THEN 
        ASSIGN tt_pessoa_fisic_integr_e.tta_cod_id_munic_fisic           = IF ttInformacaoIDICliFornec.Registration <> ? THEN ttInformacaoIDICliFornec.Registration
                                                                           ELSE tt_pessoa_fisic_integr_e.tta_cod_id_munic_fisic
               tt_pessoa_fisic_integr_e.tta_cod_id_feder                 = IF ttInformacaoIDICliFornec.TaxID <> ? THEN ttInformacaoIDICliFornec.TaxID
                                                                           ELSE tt_pessoa_fisic_integr_e.tta_cod_id_feder
               tt_pessoa_fisic_integr_e.tta_cod_id_estad_fisic           = IF ttInformacaoIDICliFornec.TaxExemptionNumber <> ? THEN ttInformacaoIDICliFornec.TaxExemptionNumber
                                                                           ELSE tt_pessoa_fisic_integr_e.tta_cod_id_estad_fisic
               tt_pessoa_fisic_integr_e.tta_cod_unid_federac_emis_estad  = IF ttInformacaoIDICliFornec.TaxExemptionIssuedState <> ? THEN ttInformacaoIDICliFornec.TaxExemptionIssuedState
                                                                           ELSE tt_pessoa_fisic_integr_e.tta_cod_unid_federac_emis_estad
               tt_pessoa_fisic_integr_e.tta_cod_orgao_emis_id_estad      = IF ttInformacaoIDICliFornec.TaxExemptionIssuedBy <> ? THEN ttInformacaoIDICliFornec.TaxExemptionIssuedBy
                                                                           ELSE tt_pessoa_fisic_integr_e.tta_cod_orgao_emis_id_estad.


    FIND FIRST ttInformacaoEspecifFornec NO-LOCK NO-ERROR.
    IF  AVAIL ttInformacaoEspecifFornec THEN
        ASSIGN tt_pessoa_fisic_integr_e.tta_cod_id_previd_social  = IF ttInformacaoEspecifFornec.SSTaxRegistration <> ? THEN ttInformacaoEspecifFornec.SSTaxRegistration /*( campo = p/ 2.04 entry(2,mgadm.emitente.char-2,chr(10)) ou p/ 2.05 mgadm.emitente.cod-inscr-inss ou emsuni.pessoa_jurid.cod_id_previd_social)*/
                                                                    ELSE tt_pessoa_fisic_integr_e.tta_cod_id_previd_social.


      FIND FIRST ttInformacaoEspecificaPF NO-LOCK NO-ERROR.
      IF AVAIL ttInformacaoEspecificaPF THEN
          ASSIGN tt_pessoa_fisic_integr_e.tta_dat_nasc_pessoa_fisic    = IF ttInformacaoEspecificaPF.DateOfBirth   <> ? THEN ttInformacaoEspecificaPF.DateOfBirth
                                                                         ELSE tt_pessoa_fisic_integr_e.tta_dat_nasc_pessoa_fisic
                 tt_pessoa_fisic_integr_e.ttv_cod_pais_nasc            = IF ttInformacaoEspecificaPF.ContryBirth   <> ? THEN ttInformacaoEspecificaPF.ContryBirth  
                                                                         ELSE tt_pessoa_fisic_integr_e.ttv_cod_pais_nasc
                 tt_pessoa_fisic_integr_e.tta_des_anot_tab             = IF ttInformacaoEspecificaPF.TableNotes_00 <> ? THEN ttInformacaoEspecificaPF.TableNotes_00
                                                                         ELSE tt_pessoa_fisic_integr_e.tta_des_anot_tab
                 tt_pessoa_fisic_integr_e.tta_nom_mae_pessoa           = IF ttInformacaoEspecificaPF.MotherName    <> ? THEN ttInformacaoEspecificaPF.MotherName   
                                                                         ELSE tt_pessoa_fisic_integr_e.tta_nom_mae_pessoa
                 tt_pessoa_fisic_integr_e.tta_nom_nacion_pessoa_fisic  = IF ttInformacaoEspecificaPF.Nacionality   <> ? THEN ttInformacaoEspecificaPF.Nacionality
                                                                         ELSE tt_pessoa_fisic_integr_e.tta_nom_nacion_pessoa_fisic
                 tt_pessoa_fisic_integr_e.tta_nom_profis_pessoa_fisic  = IF ttInformacaoEspecificaPF.Profession    <> ? THEN ttInformacaoEspecificaPF.Profession
                                                                         ELSE tt_pessoa_fisic_integr_e.tta_nom_profis_pessoa_fisic
                 tt_pessoa_fisic_integr_e.tta_ind_estado_civil_pessoa  = IF ttInformacaoEspecificaPF.MaritalStatus = 1 THEN "solteiro"   ELSE
                                                                         IF ttInformacaoEspecificaPF.MaritalStatus = 2 THEN "casado"     ELSE
                                                                         IF ttInformacaoEspecificaPF.MaritalStatus = 3 THEN "separado"   ELSE
                                                                         IF ttInformacaoEspecificaPF.MaritalStatus = 4 THEN "divorciado" ELSE
                                                                         IF ttInformacaoEspecificaPF.MaritalStatus = 5 THEN "viuvo"      ELSE 
                                                                         IF ttInformacaoEspecificaPF.MaritalStatus = 6 THEN "outros"     ELSE
                                                                            tt_pessoa_fisic_integr_e.tta_ind_estado_civil_pessoa
                 tt_pessoa_fisic_integr_e.tta_nom_ender_text           = IF ttInformacaoEspecificaPF.FullAddress <> ? THEN ttInformacaoEspecificaPF.FullAddress
                                                                         ELSE tt_pessoa_fisic_integr_e.tta_nom_ender_text.


       FIND FIRST ttInformacaoEndCobr NO-LOCK NO-ERROR.
       IF AVAIL ttInformacaoEndCobr  THEN
          ASSIGN tt_pessoa_fisic_integr_e.tta_nom_ender_cobr        = IF ttInformacaoEndCobr.Address_00 <> ? THEN ttInformacaoEndCobr.Address_00
                                                                      ELSE tt_pessoa_fisic_integr_e.tta_nom_ender_cobr
                 tt_pessoa_fisic_integr_e.tta_nom_ender_compl_cobr  = IF ttInformacaoEndCobr.AddressSuplement_00 <> ? THEN ttInformacaoEndCobr.AddressSuplement_00
                                                                      ELSE tt_pessoa_fisic_integr_e.tta_nom_ender_compl_cobr
                 tt_pessoa_fisic_integr_e.tta_nom_bairro_cobr       = IF ttInformacaoEndCobr.Address2_00 <> ? THEN ttInformacaoEndCobr.Address2_00
                                                                      ELSE tt_pessoa_fisic_integr_e.tta_nom_bairro_cobr
                 tt_pessoa_fisic_integr_e.tta_nom_cidad_cobr        = IF ttInformacaoEndCobr.City_00 <> ? THEN ttInformacaoEndCobr.City_00
                                                                      ELSE tt_pessoa_fisic_integr_e.tta_nom_cidad_cobr
                 tt_pessoa_fisic_integr_e.tta_nom_condad_cobr       = IF ttInformacaoEndCobr.County_00 <> ? THEN ttInformacaoEndCobr.County_00
                                                                      ELSE tt_pessoa_fisic_integr_e.tta_nom_condad_cobr
                 tt_pessoa_fisic_integr_e.tta_cod_unid_federac_cobr = IF ttInformacaoEndCobr.State_00 <> ? THEN ttInformacaoEndCobr.State_00
                                                                      ELSE tt_pessoa_fisic_integr_e.tta_cod_unid_federac_cobr
                 tt_pessoa_fisic_integr_e.ttv_cod_pais_cobr         = IF ttInformacaoEndCobr.Country_00 <> ? THEN ttInformacaoEndCobr.Country_00
                                                                      ELSE tt_pessoa_fisic_integr_e.ttv_cod_pais_cobr
                 tt_pessoa_fisic_integr_e.tta_cod_cep_cobr          = IF ttInformacaoEndCobr.Zip_00 <> ? THEN ttInformacaoEndCobr.Zip_00
                                                                      ELSE tt_pessoa_fisic_integr_e.tta_cod_cep_cobr
                 tt_pessoa_fisic_integr_e.tta_cod_cx_post_cobr      = IF ttInformacaoEndCobr.POBox_00 <> ? THEN ttInformacaoEndCobr.POBox_00
                                                                      ELSE tt_pessoa_fisic_integr_e.tta_cod_cx_post_cobr.

    IF CustomerVendorName <> "" THEN
        ASSIGN tt_pessoa_fisic_integr_e.tta_nom_pessoa = CustomerVendorName.

    RUN pi_atualiza_telef_pessoa (INPUT tt_pessoa_fisic_integr_e.tta_num_pessoa_fisic).
END.

PROCEDURE pi_atualiza_pessoa_juridica:

    IF CAN-FIND(FIRST tt_pessoa_jurid_integr_j) THEN RETURN.

    CREATE tt_pessoa_jurid_integr_j.
    ASSIGN tt_pessoa_jurid_integr_j.ttv_num_tip_operac          = 1
           tt_pessoa_jurid_integr_j.ttv_log_altera_razao_social = YES
           tt_pessoa_jurid_integr_j.ttv_ind_tip_pessoa_ems2     = "2".

    IF AVAIL ems.fornecedor THEN DO:
        FIND pessoa_jurid NO-LOCK WHERE
             pessoa_jurid.num_pessoa_jurid = fornecedor.num_pessoa NO-ERROR.
    END.
    ELSE IF AVAIL ems.cliente THEN DO:
        FIND pessoa_jurid NO-LOCK WHERE
             pessoa_jurid.num_pessoa_jurid = cliente.num_pessoa NO-ERROR.
    END.
    ELSE DO:
        FIND pessoa_jurid NO-LOCK WHERE
             pessoa_jurid.num_pessoa_jurid = EntityCode NO-ERROR.
    END.

    IF  AVAIL pessoa_jurid THEN DO:
        ASSIGN tt_pessoa_jurid_integr_j.tta_num_pessoa_jurid             =  pessoa_jurid.num_pessoa_jurid
               tt_pessoa_jurid_integr_j.tta_cod_telefone                 =  pessoa_jurid.cod_telefone              
               tt_pessoa_jurid_integr_j.tta_cod_fax                      =  pessoa_jurid.cod_fax                   
               tt_pessoa_jurid_integr_j.tta_cod_ramal_fax                =  pessoa_jurid.cod_ramal_fax             
               tt_pessoa_jurid_integr_j.tta_nom_home_page                =  pessoa_jurid.nom_home_page             
               tt_pessoa_jurid_integr_j.tta_cod_telex                    =  pessoa_jurid.cod_telex                 
               tt_pessoa_jurid_integr_j.tta_cod_modem                    =  pessoa_jurid.cod_modem                 
               tt_pessoa_jurid_integr_j.tta_cod_ramal_modem              =  pessoa_jurid.cod_ramal_modem           
               tt_pessoa_jurid_integr_j.tta_cod_e_mail                   =  pessoa_jurid.cod_e_mail                
               tt_pessoa_jurid_integr_j.tta_cod_id_munic_jurid           =  pessoa_jurid.cod_id_munic_jurid        
               tt_pessoa_jurid_integr_j.tta_cod_id_feder                 =  pessoa_jurid.cod_id_feder              
               tt_pessoa_jurid_integr_j.tta_cod_id_estad_jurid           =  pessoa_jurid.cod_id_estad_jurid        
               tt_pessoa_jurid_integr_j.tta_nom_endereco                 =  pessoa_jurid.nom_endereco
               tt_pessoa_jurid_integr_j.tta_nom_ender_compl              =  pessoa_jurid.nom_ender_compl
               tt_pessoa_jurid_integr_j.tta_nom_bairro                   =  pessoa_jurid.nom_bairro
               tt_pessoa_jurid_integr_j.tta_nom_cidade                   =  pessoa_jurid.nom_cidade
               tt_pessoa_jurid_integr_j.tta_nom_condado                  =  pessoa_jurid.nom_condado
               tt_pessoa_jurid_integr_j.tta_cod_pais                     =  pessoa_jurid.cod_pais
               tt_pessoa_jurid_integr_j.tta_cod_unid_federac             =  pessoa_jurid.cod_unid_federac
               tt_pessoa_jurid_integr_j.tta_cod_cep                      =  pessoa_jurid.cod_cep
               tt_pessoa_jurid_integr_j.tta_cod_cx_post                  =  pessoa_jurid.cod_cx_post
               tt_pessoa_jurid_integr_j.tta_des_anot_tab                 =  pessoa_jurid.des_anot_tab
               
               tt_pessoa_jurid_integr_j.tta_ind_tip_pessoa_jurid         =  IF      pessoa_jurid.ind_tip_pessoa_jurid = "Privada" THEN "1"
                                                                            ELSE IF pessoa_jurid.ind_tip_pessoa_jurid = "PŻblica" THEN "2"
                                                                            ELSE "3" /* Mista */

               tt_pessoa_jurid_integr_j.tta_ind_tip_capit_pessoa_jurid   = IF      pessoa_jurid.ind_tip_capit_pessoa_jurid = "Nacional"      THEN "1"
                                                                           ELSE IF pessoa_jurid.ind_tip_capit_pessoa_jurid = "Multinacional" THEN "2"
                                                                           ELSE IF pessoa_jurid.ind_tip_capit_pessoa_jurid = "Municipal"     THEN "3"
                                                                           ELSE IF pessoa_jurid.ind_tip_capit_pessoa_jurid = "Estadual"      THEN "4"
                                                                           ELSE "5" /* Federal */

               tt_pessoa_jurid_integr_j.tta_log_fins_lucrat              =  pessoa_jurid.log_fins_lucrat
               tt_pessoa_jurid_integr_j.tta_num_pessoa_jurid_pagto       =  pessoa_jurid.num_pessoa_jurid_pagto
               tt_pessoa_jurid_integr_j.tta_nom_ender_cobr               =  pessoa_jurid.nom_ender_cobr
               tt_pessoa_jurid_integr_j.tta_nom_ender_compl_cobr         =  pessoa_jurid.nom_ender_compl_cobr
               tt_pessoa_jurid_integr_j.tta_nom_bairro_cobr              =  pessoa_jurid.nom_bairro_cobr
               tt_pessoa_jurid_integr_j.tta_nom_cidad_cobr               =  pessoa_jurid.nom_cidad_cobr
               tt_pessoa_jurid_integr_j.tta_nom_condad_cobr              =  pessoa_jurid.nom_condad_cobr
               tt_pessoa_jurid_integr_j.tta_cod_unid_federac_cobr        =  pessoa_jurid.cod_unid_federac_cobr
               tt_pessoa_jurid_integr_j.ttv_cod_pais_cobr                =  pessoa_jurid.cod_pais_cobr
               tt_pessoa_jurid_integr_j.tta_cod_cep_cobr                 =  pessoa_jurid.cod_cep_cobr
               tt_pessoa_jurid_integr_j.tta_cod_cx_post_cobr             =  pessoa_jurid.cod_cx_post_cobr
               tt_pessoa_jurid_integr_j.tta_num_pessoa_jurid_matriz      =  0 /*pessoa_jurid.num_pessoa_jurid_matriz*/
               tt_pessoa_jurid_integr_j.tta_nom_pessoa                   =  pessoa_jurid.nom_pessoa
               tt_pessoa_jurid_integr_j.tta_cod_imagem                   =  pessoa_jurid.cod_imagem.

        ASSIGN SUBSTRING(tt_pessoa_jurid_integr_j.tta_nom_ender_text,1991,09) = STRING(CustomerVendorCode).

    END.

    IF CustomerVendorIdentification = 1 THEN DO:
        IF CAN-FIND(FIRST fornecedor WHERE fornecedor.cdn_fornec = CustomerVendorCode) THEN DO:
            ASSIGN SUBSTRING(tt_pessoa_jurid_integr_j.tta_nom_ender_text,1991,09) = STRING(CustomerVendorCode).
        END.
    END.

    IF CustomerVendorIdentification = 2 THEN DO:
        IF CAN-FIND(FIRST cliente WHERE cliente.cdn_cliente = CustomerVendorCode) THEN DO:
            ASSIGN SUBSTRING(tt_pessoa_jurid_integr_j.tta_nom_ender_text,1991,09) = STRING(CustomerVendorCode).
        END.
    END.

    IF tt_pessoa_jurid_integr_j.tta_cod_pais = "" THEN DO:
        IF (CustomerVendorIdentification = 1 OR
            CustomerVendorIdentification = 3) AND AVAIL tt_cliente_integr_j THEN DO:
            ASSIGN tt_pessoa_jurid_integr_j.tta_cod_pais = tt_cliente_integr_j.tta_cod_pais.
        END.

        IF (CustomerVendorIdentification = 2 OR
            CustomerVendorIdentification = 3) AND AVAIL tt_fornecedor_integr_k THEN DO:
            ASSIGN tt_pessoa_jurid_integr_j.tta_cod_pais = tt_fornecedor_integr_k.tta_cod_pais.
        END.
    END.

    IF tt_pessoa_jurid_integr_j.tta_cod_unid_federac = "" THEN
        ASSIGN tt_pessoa_jurid_integr_j.tta_cod_unid_federac = ttInformacaoEndCliFornec.State.

    IF tt_pessoa_jurid_integr_j.tta_cod_cep = "" THEN
        ASSIGN tt_pessoa_jurid_integr_j.tta_cod_cep = ttInformacaoEndCliFornec.Zip.

    IF tt_pessoa_jurid_integr_j.tta_nom_endereco = "" THEN
        ASSIGN tt_pessoa_jurid_integr_j.tta_nom_endereco = ttInformacaoEndCliFornec.Address.

    IF tt_pessoa_jurid_integr_j.tta_nom_cidade = "" THEN
        ASSIGN tt_pessoa_jurid_integr_j.tta_nom_cidade = ttInformacaoEndCliFornec.City.
    
    ASSIGN tt_pessoa_jurid_integr_j.tta_cod_imagem = IF IMAGE <> ? THEN IMAGE ELSE tt_pessoa_jurid_integr_j.tta_cod_imagem.

    FIND FIRST ttInformacaoComunicCliFornec NO-LOCK NO-ERROR.
    IF AVAIL ttInformacaoComunicCliFornec THEN
       ASSIGN tt_pessoa_jurid_integr_j.tta_cod_telefone       = IF ttInformacaoComunicCliFornec.PhoneNumber1 <> ? THEN ttInformacaoComunicCliFornec.PhoneNumber1
                                                                ELSE tt_pessoa_jurid_integr_j.tta_cod_telefone
              tt_pessoa_jurid_integr_j.tta_cod_fax            = IF ttInformacaoComunicCliFornec.FaxNumber <> ? THEN ttInformacaoComunicCliFornec.FaxNumber     
                                                                ELSE tt_pessoa_jurid_integr_j.tta_cod_fax
              tt_pessoa_jurid_integr_j.tta_cod_ramal_fax      = IF ttInformacaoComunicCliFornec.FaxExtention <> ? THEN ttInformacaoComunicCliFornec.FaxExtention
                                                                ELSE tt_pessoa_jurid_integr_j.tta_cod_ramal_fax
              tt_pessoa_jurid_integr_j.tta_nom_home_page      = IF ttInformacaoComunicCliFornec.HomePage <> ? THEN ttInformacaoComunicCliFornec.HomePage
                                                                ELSE tt_pessoa_jurid_integr_j.tta_nom_home_page
              tt_pessoa_jurid_integr_j.tta_cod_telex          = IF ttInformacaoComunicCliFornec.TelexNumber <> ? THEN ttInformacaoComunicCliFornec.TelexNumber
                                                                ELSE tt_pessoa_jurid_integr_j.tta_cod_telex
              tt_pessoa_jurid_integr_j.tta_cod_modem          = IF ttInformacaoComunicCliFornec.ModemNumber <> ? THEN ttInformacaoComunicCliFornec.ModemNumber
                                                                ELSE tt_pessoa_jurid_integr_j.tta_cod_modem
              tt_pessoa_jurid_integr_j.tta_cod_ramal_modem    = IF ttInformacaoComunicCliFornec.ModemExtention <> ? THEN ttInformacaoComunicCliFornec.ModemExtention
                                                                ELSE tt_pessoa_jurid_integr_j.tta_cod_ramal_modem
              tt_pessoa_jurid_integr_j.tta_cod_e_mail         = IF ttInformacaoComunicCliFornec.EMail <> ? THEN ttInformacaoComunicCliFornec.EMail
                                                                ELSE tt_pessoa_jurid_integr_j.tta_cod_e_mail.

    FIND FIRST ttInformacaoIDICliFornec NO-LOCK NO-ERROR.
    IF AVAIL ttInformacaoIDICliFornec THEN 
       ASSIGN tt_pessoa_jurid_integr_j.tta_cod_id_munic_jurid           = IF ttInformacaoIDICliFornec.Registration <> ? THEN ttInformacaoIDICliFornec.Registration      
                                                                          ELSE tt_pessoa_jurid_integr_j.tta_cod_id_munic_jurid
              tt_pessoa_jurid_integr_j.tta_cod_id_feder                 = IF ttInformacaoIDICliFornec.TaxID <> ? THEN ttInformacaoIDICliFornec.TaxID
                                                                          ELSE tt_pessoa_jurid_integr_j.tta_cod_id_feder
              tt_pessoa_jurid_integr_j.tta_cod_id_estad_jurid           = IF ttInformacaoIDICliFornec.TaxExemptionNumber <> ? THEN ttInformacaoIDICliFornec.TaxExemptionNumber
                                                                          ELSE tt_pessoa_jurid_integr_j.tta_cod_id_estad_jurid
              /*tt_pessoa_jurid_integr_j.tta_cod_orgao_emis_id_estad      = ttInformacaoIDICliFornec.TaxExemptionIssuedBy*/.

    FIND FIRST ttInformacaoEspecificaPJ NO-LOCK NO-ERROR.
    IF AVAILABLE ttInformacaoEspecificaPJ THEN
       ASSIGN tt_pessoa_jurid_integr_j.tta_nom_endereco                 = IF ttInformacaoEspecificaPJ.Address_01 <> ? THEN ttInformacaoEspecificaPJ.Address_01
                                                                          ELSE tt_pessoa_jurid_integr_j.tta_nom_endereco
              tt_pessoa_jurid_integr_j.tta_nom_ender_compl              = IF ttInformacaoEspecificaPJ.AddressSuplement_01 <> ? THEN ttInformacaoEspecificaPJ.AddressSuplement_01
                                                                          ELSE tt_pessoa_jurid_integr_j.tta_nom_ender_compl
              tt_pessoa_jurid_integr_j.tta_nom_bairro                   = IF ttInformacaoEspecificaPJ.Address2_01 <> ? THEN ttInformacaoEspecificaPJ.Address2_01
                                                                          ELSE tt_pessoa_jurid_integr_j.tta_nom_bairro
              tt_pessoa_jurid_integr_j.tta_nom_cidade                   = IF ttInformacaoEspecificaPJ.City_01 <> ? THEN ttInformacaoEspecificaPJ.City_01
                                                                          ELSE tt_pessoa_jurid_integr_j.tta_nom_cidade 
              tt_pessoa_jurid_integr_j.tta_nom_condado                  = IF ttInformacaoEspecificaPJ.County_01 <> ? THEN ttInformacaoEspecificaPJ.County_01
                                                                          ELSE tt_pessoa_jurid_integr_j.tta_nom_condado
              tt_pessoa_jurid_integr_j.tta_cod_pais                     = IF ttInformacaoEspecificaPJ.Country_01 <> ? THEN ttInformacaoEspecificaPJ.Country_01
                                                                          ELSE tt_pessoa_jurid_integr_j.tta_cod_pais
              tt_pessoa_jurid_integr_j.tta_cod_unid_federac             = IF ttInformacaoEspecificaPJ.State_01 <> ? THEN ttInformacaoEspecificaPJ.State_01
                                                                          ELSE tt_pessoa_jurid_integr_j.tta_cod_unid_federac
              tt_pessoa_jurid_integr_j.tta_cod_cep                      = IF ttInformacaoEspecificaPJ.Zip_01 <> ? THEN ttInformacaoEspecificaPJ.Zip_01
                                                                          ELSE tt_pessoa_jurid_integr_j.tta_cod_cep
              tt_pessoa_jurid_integr_j.tta_cod_cx_post                  = IF ttInformacaoEspecificaPJ.POBox_01 <> ? THEN ttInformacaoEspecificaPJ.POBox_01
                                                                          ELSE tt_pessoa_jurid_integr_j.tta_cod_cx_post
              tt_pessoa_jurid_integr_j.tta_des_anot_tab                 = IF ttInformacaoEspecificaPJ.TableNotes <> ? THEN ttInformacaoEspecificaPJ.TableNotes
                                                                          ELSE tt_pessoa_jurid_integr_j.tta_des_anot_tab
              tt_pessoa_jurid_integr_j.tta_ind_tip_pessoa_jurid         = STRING(ttInformacaoEspecificaPJ.CorporateEntityType)
              tt_pessoa_jurid_integr_j.tta_ind_tip_capit_pessoa_jurid   = STRING(ttInformacaoEspecificaPJ.CapitalType)
              /*tt_pessoa_jurid_integr_j.tta_ind_tip_pessoa_jurid         = IF ttInformacaoEspecificaPJ.CorporateEntityType = 1 THEN "Privada" ELSE
                                                                          IF ttInformacaoEspecificaPJ.CorporateEntityType = 2 THEN "Publica" ELSE
                                                                          IF ttInformacaoEspecificaPJ.CorporateEntityType = 3 THEN "Mista"   ELSE
                                                                             tt_pessoa_jurid_integr_j.tta_ind_tip_pessoa_jurid
              tt_pessoa_jurid_integr_j.tta_ind_tip_capit_pessoa_jurid   = IF ttInformacaoEspecificaPJ.CapitalType = 1   THEN "Nacional"      ELSE
                                                                          IF ttInformacaoEspecificaPJ.CapitalType = 2   THEN "Multinacional" ELSE
                                                                          IF ttInformacaoEspecificaPJ.CapitalType = 3   THEN "Municipal"     ELSE
                                                                          IF ttInformacaoEspecificaPJ.CapitalType = 4   THEN "Estadual"      ELSE 
                                                                          IF ttInformacaoEspecificaPJ.CapitalType = 5   THEN "Federal"       ELSE
                                                                             tt_pessoa_jurid_integr_j.tta_ind_tip_capit_pessoa_jurid        */
              tt_pessoa_jurid_integr_j.tta_log_fins_lucrat              = IF ttInformacaoEspecificaPJ.Profit <> ? THEN ttInformacaoEspecificaPJ.Profit
                                                                          ELSE tt_pessoa_jurid_integr_j.tta_log_fins_lucrat
              tt_pessoa_jurid_integr_j.tta_num_pessoa_jurid_pagto       = IF ttInformacaoEspecificaPJ.PaymentCorporateEntityCode <> ? THEN ttInformacaoEspecificaPJ.PaymentCorporateEntityCode
                                                                          ELSE tt_pessoa_jurid_integr_j.tta_num_pessoa_jurid_pagto.


    FIND FIRST ttInformacaoEndCobr NO-LOCK NO-ERROR.
    IF AVAIL ttInformacaoEndCobr  THEN
        ASSIGN tt_pessoa_jurid_integr_j.tta_nom_ender_cobr             = IF ttInformacaoEndCobr.Address_00 <> ? THEN ttInformacaoEndCobr.Address_00
                                                                         ELSE tt_pessoa_jurid_integr_j.tta_nom_ender_cobr
               tt_pessoa_jurid_integr_j.tta_nom_ender_compl_cobr       = IF ttInformacaoEndCobr.AddressSuplement_00 <> ? THEN ttInformacaoEndCobr.AddressSuplement_00
                                                                         ELSE tt_pessoa_jurid_integr_j.tta_nom_ender_compl_cobr
               tt_pessoa_jurid_integr_j.tta_nom_bairro_cobr            = IF ttInformacaoEndCobr.Address2_00 <> ? THEN ttInformacaoEndCobr.Address2_00
                                                                         ELSE tt_pessoa_jurid_integr_j.tta_nom_bairro_cobr
               tt_pessoa_jurid_integr_j.tta_nom_cidad_cobr             = IF ttInformacaoEndCobr.City_00 <> ? THEN ttInformacaoEndCobr.City_00
                                                                         ELSE tt_pessoa_jurid_integr_j.tta_nom_cidad_cobr
               tt_pessoa_jurid_integr_j.tta_nom_condad_cobr            = IF ttInformacaoEndCobr.County_00 <> ? THEN ttInformacaoEndCobr.County_00
                                                                         ELSE tt_pessoa_jurid_integr_j.tta_nom_condad_cobr
               tt_pessoa_jurid_integr_j.tta_cod_unid_federac_cobr      = IF ttInformacaoEndCobr.State_00 <> ? THEN ttInformacaoEndCobr.State_00
                                                                         ELSE tt_pessoa_jurid_integr_j.tta_cod_unid_federac_cobr
               tt_pessoa_jurid_integr_j.ttv_cod_pais_cobr              = IF ttInformacaoEndCobr.Country_00 <> ? THEN ttInformacaoEndCobr.Country_00
                                                                         ELSE tt_pessoa_jurid_integr_j.ttv_cod_pais_cobr
               tt_pessoa_jurid_integr_j.tta_cod_cep_cobr               = IF ttInformacaoEndCobr.Zip_00 <> ? THEN ttInformacaoEndCobr.Zip_00
                                                                         ELSE tt_pessoa_jurid_integr_j.tta_cod_cep_cobr
               tt_pessoa_jurid_integr_j.tta_cod_cx_post_cobr           = IF ttInformacaoEndCobr.POBox_00 <> ? THEN ttInformacaoEndCobr.POBox_00
                                                                         ELSE tt_pessoa_jurid_integr_j.tta_cod_cx_post_cobr.
    
    FIND FIRST ttInformacaoMatrizCliFornec NO-LOCK NO-ERROR.
    IF AVAIL ttInformacaoMatrizCliFornec THEN DO:
        ASSIGN tt_pessoa_jurid_integr_j.tta_num_pessoa_jurid_matriz = IF ttInformacaoMatrizCliFornec.CustomerVendorMatrixCode <> ? THEN ttInformacaoMatrizCliFornec.CustomerVendorMatrixCode
                                                                      ELSE tt_pessoa_jurid_integr_j.tta_num_pessoa_jurid_matriz.
               /*tt_pessoa_jurid_integr_j.tta_nom_pessoa              = IF ttInformacaoMatrizCliFornec.CustomerVendorMatrixName <> ? THEN ttInformacaoMatrizCliFornec.CustomerVendorMatrixName
                                                                      ELSE tt_pessoa_jurid_integr_j.tta_nom_pessoa*/
    END.

    IF CustomerVendorName <> "" THEN
        ASSIGN tt_pessoa_jurid_integr_j.tta_nom_pessoa = CustomerVendorName.

    RUN pi_atualiza_telef_pessoa (INPUT tt_pessoa_jurid_integr_j.tta_num_pessoa_jurid).

    RUN pi_atualiza_ender_entrega_pj (INPUT tt_pessoa_jurid_integr_j.tta_num_pessoa_jurid).

    RUN pi_atualiza_ativid_pj (INPUT tt_pessoa_jurid_integr_j.tta_num_pessoa_jurid).

    RUN pi_atualiza_ramo_negoc_pj (INPUT tt_pessoa_jurid_integr_j.tta_num_pessoa_jurid).

    RUN pi_atualiza_porte_pj (INPUT tt_pessoa_jurid_integr_j.tta_num_pessoa_jurid).
END.


PROCEDURE pi_atualiza_contatos:

    FOR EACH ttCustomerVendorContactIn_00:
        /*Valores possiveis= 1- Fisica  2- Juridica)*/
        IF  EntityType = 1 THEN 
            ASSIGN tt_contato_integr_e.tta_num_pessoa_fisic = EntityCode.
        ELSE
            ASSIGN tt_contato_integr_e.tta_num_pessoa_jurid = EntityCode.


        CREATE tt_contato_integr_e.
        ASSIGN tt_contato_integr_e.ttv_num_tip_operac          = 1
               tt_contato_integr_e.tta_nom_abrev_contat        = ttCustomerVendorContactIn_00.ContactName
               tt_contato_integr_e.tta_nom_pessoa              = ttCustomerVendorContactIn_00.ContactName
               tt_contato_integr_e.tta_cod_telef_contat        = ttCustomerVendorContactIn_00.ContactPhone
               tt_contato_integr_e.tta_cod_ramal_contat        = ttCustomerVendorContactIn_00.ContactPhoneExtention
               tt_contato_integr_e.tta_cod_fax_contat          = ttCustomerVendorContactIn_00.ContactFaxNumber
               tt_contato_integr_e.tta_cod_ramal_fax_contat    = ttCustomerVendorContactIn_00.ContactFaxExtention
               tt_contato_integr_e.tta_cod_modem_contat        = ttCustomerVendorContactIn_00.ContactModemNumber
               tt_contato_integr_e.tta_cod_ramal_modem_contat  = ttCustomerVendorContactIn_00.ContactModemExtention
               tt_contato_integr_e.tta_cod_e_mail_contat       = ttCustomerVendorContactIn_00.ContactEMail
               tt_contato_integr_e.tta_ind_priorid_envio_docto = IF ttCustomerVendorContactIn_00.SendPriority = 1 THEN "E-mail / Fax" ELSE 
                                                                 IF ttCustomerVendorContactIn_00.SendPriority = 2 THEN "Fax / E-mail" ELSE 
                                                                    tt_contato_integr_e.tta_ind_priorid_envio_docto
               tt_contato_integr_e.tta_cdn_cliente             = IF AVAIL tt_clien_financ_integr_e  THEN tt_clien_financ_integr_e.tta_cdn_cliente ELSE 0
               tt_contato_integr_e.tta_cdn_fornecedor          = IF AVAIL tt_fornec_financ_integr_d THEN tt_fornec_financ_integr_d.tta_cdn_fornecedor ELSE 0
               tt_contato_integr_e.tta_nom_endereco            = ttCustomerVendorContactIn_00.Address
               tt_contato_integr_e.tta_nom_ender_compl         = ttCustomerVendorContactIn_00.AddressSuplement
               tt_contato_integr_e.tta_nom_bairro              = ttCustomerVendorContactIn_00.Address2
               tt_contato_integr_e.tta_nom_cidade              = ttCustomerVendorContactIn_00.City
               tt_contato_integr_e.tta_cod_pais                = ttCustomerVendorContactIn_00.Country
               tt_contato_integr_e.tta_cod_cx_post             = ttCustomerVendorContactIn_00.POBox
               tt_contato_integr_e.tta_cod_unid_federac        = ttCustomerVendorContactIn_00.State
               tt_contato_integr_e.tta_cod_cep_cobr            = ttCustomerVendorContactIn_00.Zip.
               

             RUN pi_atualiza_idioma_contato.

             RUN pi_atualiza_classes_contato.

    END.

END.


