PROCEDURE pi_atualiza_ender_entrega_pj:
    DEFINE INPUT  PARAMETER pi_num_pessoa AS INTEGER    NO-UNDO.

    FOR EACH ttCorporateShipToAddressI_00 OF ttInformacaoEspecificaPJ:
      
      CREATE tt_ender_entreg_integr_e.
     
      /*verificar se existe um registro em ender_entreg para este enderećo, 
      se existir pode ser uma alteraćŲo, entŲo deve ser considerado como default
      aquilo que jĀ existir na base*/
      ASSIGN tt_ender_entreg_integr_e.ttv_num_tip_operac          = 1
             tt_ender_entreg_integr_e.tta_num_pessoa_jurid        = pi_num_pessoa
             tt_ender_entreg_integr_e.tta_cod_ender_entreg        = ttCorporateShipToAddressI_00.CorporateShipToAddressCode
