             tt_ender_entreg_integr_e.tta_nom_cidad_entreg        = ttCorporateShipToAddressI_00.City             
             tt_ender_entreg_integr_e.tta_cod_pais                = ttCorporateShipToAddressI_00.Country
             tt_ender_entreg_integr_e.tta_cod_unid_federac_entreg = ttCorporateShipToAddressI_00.State
             tt_ender_entreg_integr_e.tta_cod_cep_entreg          = ttCorporateShipToAddressI_00.Zip
             tt_ender_entreg_integr_e.tta_cod_cx_post_entreg      = ttCorporateShipToAddressI_00.POBox
             tt_ender_entreg_integr_e.tta_nom_ender_entreg_text   = ttCorporateShipToAddressI_00.corporateFullShipToAddress.
    END.
END.

