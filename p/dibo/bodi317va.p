PROCEDURE setRecordHandle :
/*------------------------------------------------------------------------------
  Purpose:     Seta registro na temptable RowObject
  Parameters:  recebe handle da temptable RowObject
  Notes: procedure solicitada pelo pessoal do EMS5 em 06/2020      
------------------------------------------------------------------------------*/
    DEFINE INPUT PARAMETER pHdlRowObject AS HANDLE NO-UNDO.

    DEFINE VARIABLE hdlBufferTT    AS HANDLE NO-UNDO.
    DEFINE VARIABLE hdlBufferTTAux AS HANDLE NO-UNDO.
    DEFINE VARIABLE hdlQueryTT     AS HANDLE NO-UNDO.

    ASSIGN hdlBufferTT = pHdlRowObject:DEFAULT-BUFFER-HANDLE.

    CREATE QUERY hdlQueryTT.
    hdlQueryTT:SET-BUFFERS(hdlBufferTT).
    hdlQueryTT:QUERY-PREPARE('FOR EACH ' + pHdlRowObject:NAME).
    hdlQueryTT:QUERY-OPEN(). 

    /* Limpa temptable */
    RUN emptyRowObjectAux IN THIS-PROCEDURE.

    ASSIGN hdlBufferTTAux = BUFFER RowObjectAux:HANDLE.

    REPEAT:
        hdlQueryTT:GET-NEXT().
        IF hdlQueryTT:QUERY-OFF-END THEN LEAVE.

        CREATE RowObjectAux.
        hdlBufferTTAux:BUFFER-COPY(hdlBufferTT).
    END.

    hdlQueryTT:QUERY-CLOSE().
    hdlBufferTT:BUFFER-RELEASE().
    hdlBufferTTAux:BUFFER-RELEASE().

    DELETE OBJECT hdlQueryTT. 

    RUN setRecord (INPUT TABLE RowObjectAux).

    RETURN "OK":U.
        
END PROCEDURE.

/* _UIB-CODE-BLOCK-END */








