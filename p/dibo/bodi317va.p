PROCEDURE liberaWtDoctoDoEbmarque:
    /*PROCEDURE liberaWtDoctoDoEbmarque:*/
    /* Definição dos parâmetros de Entrada/Saída */
    def input  param p-de-cdd-embarq     like res-cli.cdd-embarq    no-undo.
    def output param p-l-procedimento-ok as log                     no-undo.

    assign c-ultimo-metodo-exec = replace(program-name(1)," ":U, "~~":U).

    /* Localiza wt-docto */

    release wt-docto.
    for each wt-docto
        where wt-docto.cdd-embarq = p-de-cdd-embarq 
        AND   wt-docto.nr-embarque = 0 no-lock:
    end.

    assign p-l-procedimento-ok = yes. /* Indica que o processo ocorreu por completo */
/*END PROCEDURE.    */
 
END PROCEDURE.

