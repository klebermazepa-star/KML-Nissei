/* 

grava no extrato de versao uma linha contendo o nome da funþao
e se ela esta ativa ou nao e qual arquivo a chamou

*/
IF c-arquivo-log <> "" AND c-arquivo-log <> ? THEN DO:
    OUTPUT TO VALUE(c-arquivo-log) APPEND.
         PUT UNFORMATTED "CD7070 | " + "FN-ESTAB-FORMA-EMIS" + " | " + STRING(YES) + " | " + "bodi317va.m08" SKIP.
    OUTPUT CLOSE.
END. 
  
            
             RUN cdp/cd8700.p (INPUT p-c-cod-estabel,
                               input p-c-serie,
                               INPUT-OUTPUT i-forma-emis).
          END.
          ELSE DO:
                /* 

Grava no clientlog uma linha contendo o nome da funþao
e se ela esta ativa ou nao e qual arquivo a chamou

*/
IF LOG-MANAGER:LOGGING-LEVEL > 2 THEN
    LOG-MANAGER:WRITE-MESSAGE("FN-ESTAB-FORMA-EMIS" + " | " + STRING(NO) + " | " + "bodi317va.m08", "CD7070") NO-ERROR.

/* 

grava no extrato de versao uma linha contendo o nome da funþao
