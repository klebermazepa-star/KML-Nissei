         PUT UNFORMATTED "CD7070 | " + "FN-ESTAB-FORMA-EMIS" + " | " + STRING(NO) + " | " + "bodi317va.m08" SKIP.
    OUTPUT CLOSE.
END. 
  
          END.
      
    /*====================================================*/

