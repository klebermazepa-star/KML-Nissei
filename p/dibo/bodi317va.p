     Objetivo: Valida a quantidade no saldo em poder de terceiros, quando feita manuten╗Æo.
          

 Parâmetros de Entrada/Sa¡da:
   Entrada: p-c-cod-emitente....: C¢digo do emitente do saldo em poder de terceiros;
            p-c-nro-docto.......: N£mero do saldo em poder de terceiros;
            p-c-serie-docto.....: S▓rie do saldo em poder de terceiros;
            p-c-nat-operacao....: Natureza de opera╗Æo do saldo em poder de terceiros;
            p-c-it-codigo.......: Item do saldo em poder de terceiros;
            p-c-cod-refer.......: Refer╝ncia do saldo em poder de terceiros;
            p-i-sequencia.......: Seque╝ncia do saldo em poder de terceiros;
            p-de-quantidade.....: Quantidade que ir  ser alocada ou desalocada;
   Saida..: p-l-procedimento-ok.: Retorna que o procedimento ocorreu por completo;


--------------------------------------------------------------------------------------------------------*/

PROCEDURE validaQtSaldoTercEntFut:
  /*PROCEDURE validaQtSaldoTercEntFut:*/
    /* Defini╗Æo dos par│metros de Entrada/Sa¡da */
    def input  param p-c-cod-emitente     like saldo-terc.cod-emitente no-undo.
    def input  param p-c-nro-docto        like saldo-terc.nro-docto    no-undo.
    def input  param p-c-serie-docto      like saldo-terc.serie-docto  no-undo.
    def input  param p-c-nat-operacao     like saldo-terc.nat-operacao no-undo.
    def input  param p-c-it-codigo        like saldo-terc.it-codigo    no-undo.
    def input  param p-c-cod-refer        like saldo-terc.cod-refer    no-undo.
    def input  param p-i-sequencia        like saldo-terc.sequencia    no-undo.
    def input  param p-de-quantidade-atu  as dec                       no-undo.
    def output param p-l-procedimento-ok  as log                       no-undo.

    DEF VAR de-qt-saldo AS DEC  NO-UNDO.

    assign c-ultimo-metodo-exec = replace(program-name(1)," ":U, "~~":U).

    for first saldo-terc 
        where saldo-terc.serie-docto  = p-c-serie-docto
        and   saldo-terc.nro-docto    = p-c-nro-docto
        and   saldo-terc.cod-emitente = p-c-cod-emitente
        and   saldo-terc.nat-operacao = p-c-nat-operacao
        and   saldo-terc.it-codigo    = p-c-it-codigo
        and   saldo-terc.cod-refer    = p-c-cod-refer
        and   saldo-terc.sequencia    = p-i-sequencia NO-LOCK:
        /* Inicializa a variável de qt saldo com a quantidade inicial */
        ASSIGN de-qt-saldo = saldo-terc.quantidade.
        FOR EACH  componente
            WHERE componente.cod-emitente = saldo-terc.cod-emitente 
            AND   componente.nro-comp     = saldo-terc.nro-docto    
            AND   componente.serie-comp   = saldo-terc.serie-docto  
            AND   componente.nat-comp     = saldo-terc.nat-operacao 
            AND   componente.it-codigo    = saldo-terc.it-codigo    
            AND   componente.cod-refer    = saldo-terc.cod-refer   
            AND   componente.seq-comp     = saldo-terc.sequencia NO-LOCK:
            IF  componente.componente = 1 THEN 
                /* Diminui a quantidade de produtos que já foram enviados */
                ASSIGN de-qt-saldo = de-qt-saldo - componente.quantidade.
            ELSE
                /* Aumenta a quantidade de produtos que foram devolvidos */
                ASSIGN de-qt-saldo = de-qt-saldo + componente.quantidade.
        END.
        /* Se for menor ou igual a zero, esse item deverá ser desconsiderado */
        IF p-de-quantidade-atu > de-qt-saldo then do:
            /* MENSAGEM: 28835 - Quantidade informada maior que a quantidade em aberto */
            
