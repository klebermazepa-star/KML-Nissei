run trataErros(input l-proc-ok-aux, input " ", input ?).
if  not l-proc-ok-aux then return.

/*  BODI317.I5  */
 
end.

FOR FIRST estabelec NO-LOCK
    WHERE estabelec.cod-estabel = wt-docto.cod-estabel.
END.

IF  AVAIL estabelec THEN
    FOR FIRST unid-feder no-lock
        where unid-feder.pais   = estabelec.pais
        and   unid-feder.estado = estabelec.estado:
    END.

ASSIGN l-sta-media =     AVAIL para-fat 
                     AND substring(para-fat.char-2,96,1)  = "S"   /* Bloqueia Emissão NF sem média base STA calculada (FT0301) */   
                     AND AVAIL unid-feder
                     AND SUBSTRING(unid-feder.char-1,14,1) = "S". /* Calcular o STA pela Média Ponderada (CD0904) */

if wt-docto.ind-tip-nota <> 8 then do: /* Recebimento */

    if  not avail para-fat then
       find first para-fat no-lock no-error.    
       
    if  avail para-fat  
    and (   substring(para-fat.char-1,105,1) = "S"        /* Bloqueia Emiss├úo NF CST 60 sem saldo ICMS ST (FT0301) */ 
         OR l-sta-media ) 
    then do:

        ASSIGN c-lista-itens = "".

        IF  l-sta-media THEN
            RUN dibo/bodi01102.p PERSISTENT SET h-bodi01102.

        for each wt-it-docto no-lock
           where wt-it-docto.seq-wt-docto = wt-docto.seq-wt-docto
             and wt-it-docto.calcula:
             
            for first natur-oper no-lock
                where natur-oper.nat-operacao = wt-it-docto.nat-operacao:
            end.
            
            if  natur-oper.terceiros
            or  (    not wt-it-docto.baixa-estoq
                 and not (b-natur-oper-it-doc.log-icms-substto-antecip or natur-oper.log-contrib-st-antec)) then
                next.

            if  not can-find(first item-entr-st no-lock
                             where item-entr-st.cod-estab = wt-docto.cod-estabel
                               and item-entr-st.cod-item  = wt-it-docto.it-codigo) then
                next.

            IF  avail para-fat  
            and substring(para-fat.char-1,105,1) = "S" THEN DO:
               
                assign de-saldo-sta = 0.   
                    
                for each item-entr-st 
                   where item-entr-st.cod-estab = wt-docto.cod-estabel
                     and item-entr-st.cod-item  = wt-it-docto.it-codigo
                     and not item-entr-st.log-finaliz no-lock:
                    
                    
                    assign de-saldo-sta = de-saldo-sta + (item-entr-st.qtd-sdo-final - item-entr-st.val-livre-2).
                end.                
                
                if de-saldo-sta < wt-it-docto.quantidade[1] then do:
                    
