*******************************************************************************/

/********************************************************************************
** Programa : include/i-epc200.i2
**
** Data : 04/05/1999
**
** Criacao : John Cleber Jaraceski
**
** Objetivo : Padronizar a criacao de registro para a Temp-Table tt-epc. 
**            Esta Temp-Table é utilizada em programas em EPCs de Pontos Estrat.
** 
** Parametros :
**     . {&CodEvent}: sera utilizado para atribuir valor ao campo 
**                    tt-epc.cod-event
**     . {&CodParameter}: sera utilizado para atribuir valor ao campo
**                        tt-epc.cod-parameter
**     . {&ValueParameter: sera utilizada para atribuir valor ao campo
**                         tt-epc.val-parameter
**
** Ultima Alt : 
*******************************************************************************/


    CREATE tt-epc.
    ASSIGN tt-epc.cod-event     = 'ValidatePercMaxDesc'
           tt-epc.cod-parameter = 'FatBalcao'
           tt-epc.val-parameter = ?.

 
        
        /***************************************************************
**
** I-EPC201.I - Padroniza a chamada dos programas de integraþÒo/
**              customizaþÒo.
**
** {1}        - ind-event
**
***************************************************************/ 

/* begin_epc_call*/

/* DPC */
if c-nom-prog-dpc-mg97  <> "" and
   c-nom-prog-dpc-mg97  <> ?  then do:

   run value( c-nom-prog-dpc-mg97  ) 
            ( "ValidatePercMaxDesc", 
              input-output table tt-epc
            ).
end.                                     

/* APPC */
if c-nom-prog-appc-mg97  <> "" and
   c-nom-prog-appc-mg97  <> ?  then do:

   run value( c-nom-prog-appc-mg97  ) 
            ( "ValidatePercMaxDesc", 
              input-output table tt-epc
            ).
end.                                     

/**************************************************
** Controle de UPC por Evento
**************************************************/
/* Se o programa possuir a definicação da include/epc-mft-200.i */
    if can-find(first control-upc-prog
                where control-upc-prog.cod-prog-dtsul = 'BODI317VA'
                  and control-upc-prog.log-ativo) then do: /* Se o programa estiver cadastrado e ativo, deve-se verificar os eventos cadastrados para ele */
        if can-find(first control-upc-evento 
                        where control-upc-evento.cod-prog-dtsul = 'BODI317VA'
                      and control-upc-evento.cod-evento = "ValidatePercMaxDesc"
                              and control-upc-evento.log-ativo) then do: /* O evento só deve ser executado se estiver cadastrado e ativo */
            
            /* upc */
            if c-nom-prog-upc-mg97   <> "" and
               c-nom-prog-upc-mg97   <> ?  then do:
            
                  run value( c-nom-prog-upc-mg97  )
                        ( "ValidatePercMaxDesc", 
                           input-output table tt-epc
                        ).        
            end.
        end.
    end.
    else do:
        /* upc */
        if c-nom-prog-upc-mg97   <> "" and
           c-nom-prog-upc-mg97   <> ?  then do:
        
              run value( c-nom-prog-upc-mg97  )
                    ( "ValidatePercMaxDesc", 
                       input-output table tt-epc
                    ).        
        end.
    end.





/* end_epc_call*/
 
        
        for first tt-epc where
            tt-epc.cod-event     = "ValidatePercMaxDesc" and
            tt-epc.cod-parameter = "FatBalcao" and
            tt-epc.val-parameter = "RetornaOK":
            assign p-l-procedimento-ok = yes.
            return "".
        end.
    END.
    /*-------- UPC Valida Orçamento Fat Balcão ---------*/
    
    run localizaWtDocto (input  p-i-seq-wt-docto,
                         output l-proc-ok-aux).

    if  avail wt-docto then
        for first param-fb
            where param-fb.cod-estabel = wt-docto.cod-estabel 
            and   param-fb.senha       <> "":U no-lock:
            

            for each wt-it-docto no-lock
                where wt-it-docto.seq-wt-docto = wt-docto.seq-wt-docto
                and   wt-it-docto.calcula:

                assign de-tot-merc-liq = de-tot-merc-liq + wt-it-docto.vl-merc-liq
                       de-tot-merc-ori = de-tot-merc-ori + wt-it-docto.vl-merc-ori
                       de-tot-tab-pre  = de-tot-tab-pre  + wt-it-docto.vl-pretab * wt-it-docto.quantidade[1].
            end.

            if  (1 - de-tot-merc-liq / de-tot-tab-pre) * 100 > param-fb.desconto
            and encode(p-c-senha) <> param-fb.senha then do:
                
