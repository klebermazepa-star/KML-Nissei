PROCEDURE validaAtualizaoEstoqueNotasDevolMerc:
  /* validaAtualizaoEstoqueNotasDevolMerc */

/******************************************************************************************************************************************************************
 *
 * O registro da rat-componente para as notas de devolucao de mercadoria somente sao criados na atualizacao do estoque. 
 * Para que o controle do saldo em poder de terceiros funcione corretamente, e necessario que a nota dessa devolucao de mercadoria seja atualizada no estoque.
 * Aprocedure verifica cada uma das notas de devolucao de mercadoria que referenciam a nota de remessa e valida se a mesma esta atualizada no estoque.   
 *
 ******************************************************************************************************************************************************************/

    def input  param p-i-seq-wt-docto    like wt-it-docto.seq-wt-docto no-undo.
    def input  param p-c-serie-terc      like saldo-terc.serie-docto   no-undo.
    def input  param p-c-nr-nota-terc    like saldo-terc.nro-docto     no-undo.
    def input  param p-c-nat-oper-terc   like saldo-terc.nat-operacao  no-undo.
    
    def var txt-1 as char no-undo.
    def var txt-2 as char no-undo.
    def var txt-3 as char no-undo.

    valida-atualizacao-estoque:
    for first b-wt-docto 
        where b-wt-docto.seq-wt-docto = p-i-seq-wt-docto no-lock:
                
        for first natur-oper 
            where natur-oper.nat-operacao = b-wt-docto.nat-operacao no-lock:
        end.
                 
        if  natur-oper.terceiros             /* Operacao com terceiros */
        and natur-oper.tipo = 2              /* Saida */
        and (natur-oper.tp-oper-terc = 5     /* Devolucao Consignacao de Mercadoria ou Simbolica */
        or   natur-oper.tp-oper-terc = 2     /* Retorno de Beneficiamento */
        or   natur-oper.tp-oper-terc = 9     /* Retorno Depósito Fechado  */
        or   natur-oper.tp-oper-terc = 11)   /* Retorno Armazém Geral     */
        then 
                
        for each it-nota-fisc use-index ch-nota-docum
           where it-nota-fisc.cod-estabel = b-wt-docto.cod-estabel
             and it-nota-fisc.serie-docum = p-c-serie-terc 
             and it-nota-fisc.nr-docum    = p-c-nr-nota-terc no-lock break by nr-nota-fis:                        
                         
             find first item 
                  where item.it-codigo = it-nota-fisc.it-codigo no-lock no-error.
                        
            if avail item and item.tipo-con-est = 3 then do: /* Itens controlados por lote */
                if first-of(it-nota-fisc.nr-nota-fis) then do: 
                    for first b-nota-fiscal
                        where b-nota-fiscal.cod-estabel = it-nota-fisc.cod-estabel
                          and b-nota-fiscal.serie       = it-nota-fisc.serie
                          and b-nota-fiscal.nr-nota-fis = it-nota-fisc.nr-nota-fis no-lock:
                                                        
                        if  b-nota-fiscal.dt-confirma = ?                        
                        and b-nota-fiscal.dt-cancela  = ? then do:
                                              
                            for first b-natur-oper 
                                where b-natur-oper.nat-operacao = b-nota-fiscal.nat-operacao no-lock:
                                                            
                                if  b-natur-oper.terceiros                              
                                and b-natur-oper.tipo = 2                               
                                and ((b-natur-oper.tp-oper-terc = 5 and b-natur-oper.idi-tip-devol-consig = 2) 
                                or   (b-natur-oper.tp-oper-terc = 2 or b-natur-oper.tp-oper-terc = 9 or b-natur-oper.tp-oper-terc = 11))  then do: 
                                              
                                    /**********************************************************************
**
**  UT-LITER.I - Chamada pardrão para UT-LITER.P
**
*********************************************************************/

run utp/ut-liter.p (input "Atenção!",
                    input "",
                    input "") no-error.


/* ut-liter.i */                    
 
                                    assign txt-1 = return-value.  
                                    /**********************************************************************
**
**  UT-LITER.I - Chamada pardrão para UT-LITER.P
**
*********************************************************************/

run utp/ut-liter.p (input "Já_existe_um_nota_fiscal_de_devolução/retorno_para_essa_remessa._Favor_atualizar_a_nota_fiscal ",
                    input "",
                    input "") no-error.


/* ut-liter.i */                    
 
                                    assign txt-2 = return-value.
                                    /**********************************************************************
**
**  UT-LITER.I - Chamada pardrão para UT-LITER.P
**
*********************************************************************/

run utp/ut-liter.p (input " no_estoque_para_que_o_controle_dos_saldos_em_poder_de_terceiros_funcione_corretamente.",
                    input "",
                    input "") no-error.


