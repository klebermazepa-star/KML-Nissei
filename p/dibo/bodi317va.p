                    empty temp-table tt-epc.
        
                    CREATE tt-epc.
                    ASSIGN tt-epc.cod-event     = "ValidaFaturamentoAntecipado"
                           tt-epc.cod-parameter = "Return"
                           tt-epc.val-parameter = "".
        
