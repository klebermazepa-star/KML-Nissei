/*-------------------------------------------------------------------------------------------------------

 Procedimento: validaCabecalhoDoEmbarque.

     Objetivo: Validar os campos do cabeçalho do programa de faturamento de embarques.
     

 Parâmetros de Entrada/Saída:
   Entrada: p-i-nr-embarque....: Número do embarque.
            p-c-cod-estabel....: Cód do estabelecimento
            p-c-serie..........: Série
            p-da-dt-emis-nota..: data de emissão da nota
            p-da-dt-base-dup...: data base para geração de duplicatas
            p-da-dt-prvenc.....: data do primeiro vencimento
   Saída..: p-l-procedimento-ok: Retorna que o procedimento ocorreu por completo.
                      

--------------------------------------------------------------------------------------------------------*/

PROCEDURE validaCabecalhoDoEmbarque:
  /*PROCEDURE validaCabecalhoDoEmbarque:*/
    /* Definicao de parametros */
    def input  param p-de-cdd-embarq     like wt-docto.cdd-embarq      no-undo. 
    def input  param p-c-cod-estabel     like wt-docto.cod-estabel     no-undo.
    def input  param p-c-serie           like wt-docto.serie           no-undo.
    def input  param p-da-dt-emis-nota   like wt-docto.dt-emis-nota    no-undo.
    def input  param p-da-dt-base-dup    like wt-docto.dt-base-dup     no-undo.
    def input  param p-da-dt-prvenc      like wt-docto.dt-prvenc       no-undo.
    def output param p-l-procedimento-ok as   logi                     no-undo.

    assign c-ultimo-metodo-exec = replace(program-name(1)," ":U, "~~":U).

    run validaCodEstabel(input  p-c-cod-estabel,
                         output l-proc-ok-aux).

    run validaSerie(input  p-c-serie,
                    input  1, /* p-i-ind-tip-nota */
                    output l-proc-ok-aux).

    run validaSerEstab(input  p-c-serie,
                       input  p-c-cod-estabel,
                       output l-proc-ok-aux).

    if  avail serie
        and serie.serie <> serie.serie-vinc then 
            run validaSerEstab(input  serie.serie-vinc,
                               input  p-c-cod-estabel,
                               output l-proc-ok-aux).

    ASSIGN c-cod-cfop = "".
                               
    run validaDtEmisNota(input  p-c-cod-estabel,
                         input  p-c-serie,
                         input  p-da-dt-emis-nota,
                         input  p-de-cdd-embarq,
                         output l-proc-ok-aux).

    run validaDtBaseDup(input  p-da-dt-base-dup,
                        input  p-da-dt-emis-nota,
                        output l-proc-ok-aux).

    run validaDtPrVenc(input  p-da-dt-prvenc,
                       input  p-da-dt-emis-nota,
                       output l-proc-ok-aux).

    run validaDtBasePrVenc(input  p-da-dt-prvenc,
                           input  p-da-dt-base-dup,
                           output l-proc-ok-aux).

    find first RowErrors
         where RowErrors.ErrorSubType = "ERROR":U no-error.
    if  avail RowErrors then
        return.

    assign p-l-procedimento-ok = yes. 
/*END PROCEDURE.    */
  /* PROCEDURE validaCabecalhoDoEmbarque: */
END PROCEDURE.    


