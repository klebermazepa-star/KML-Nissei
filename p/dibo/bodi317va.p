    def input  param p-da-dt-emis-nota   as   date                     no-undo.
    def input  param p-de-cdd-embarq     like nota-fiscal.cdd-embarq   no-undo.
    def input  param p-c-nat-operacao    like nota-fiscal.nat-operacao no-undo.
    def output param p-l-procedimento-ok as   log                      no-undo.
    
    def var c-desc-cia        as character no-undo.
    def var c-sit-cia         as character no-undo.
    def var lShowMessage27565 as logical   no-undo.
    def var l-devol-consig    as integer   no-undo.
    
    def buffer b-natur-oper for natur-oper.

    /* Verificar se o pedido de venda existe */
    find ped-venda
         where ped-venda.nome-abrev = p-c-nome-abrev 
         and   ped-venda.nr-pedcli  = p-c-nr-pedcli exclusive-lock no-wait no-error.

     /* UPC para permitir desbloquear o pedido de venda */
     if  c-nom-prog-upc-mg97 <> "" then do:
         for each tt-epc 
             where tt-epc.cod-event = "Unlock_Ped-venda":
             delete tt-epc.
         end.
        
         create tt-epc.
         assign tt-epc.cod-event     = "Unlock_Ped-venda"
                tt-epc.cod-parameter = "Object-Handle"
                tt-epc.val-parameter = STRING(THIS-PROCEDURE:HANDLE).
        
          create tt-epc.
          assign tt-epc.cod-event     = "Unlock_Ped-venda"
                 tt-epc.cod-parameter = "nome-abrev"
                 tt-epc.val-parameter = emitente.nome-abrev.
        
          create tt-epc.
          assign tt-epc.cod-event     = "Unlock_Ped-venda"
                 tt-epc.cod-parameter = "nr-pedcli"
                 tt-epc.val-parameter = p-c-nr-pedcli.
                 
         /***************************************************************
**
** I-EPC201.I - Padroniza a chamada dos programas de integraþÒo/
**              customizaþÒo.
**
** {1}        - ind-event
**
***************************************************************/ 

/* begin_epc_call*/

/* DPC */
if c-nom-prog-dpc-mg97  <> "" and
   c-nom-prog-dpc-mg97  <> ?  then do:

   run value( c-nom-prog-dpc-mg97  ) 
            ( "Unlock_Ped-venda", 
              input-output table tt-epc
            ).
end.                                     

/* APPC */
if c-nom-prog-appc-mg97  <> "" and
   c-nom-prog-appc-mg97  <> ?  then do:

   run value( c-nom-prog-appc-mg97  ) 
            ( "Unlock_Ped-venda", 
              input-output table tt-epc
            ).
end.                                     

/**************************************************
** Controle de UPC por Evento
**************************************************/
/* Se o programa possuir a definicação da include/epc-mft-200.i */
    if can-find(first control-upc-prog
                where control-upc-prog.cod-prog-dtsul = 'BODI317VA'
                  and control-upc-prog.log-ativo) then do: /* Se o programa estiver cadastrado e ativo, deve-se verificar os eventos cadastrados para ele */
        if can-find(first control-upc-evento 
                        where control-upc-evento.cod-prog-dtsul = 'BODI317VA'
                      and control-upc-evento.cod-evento = "Unlock_Ped-venda"
                              and control-upc-evento.log-ativo) then do: /* O evento só deve ser executado se estiver cadastrado e ativo */
            
            /* upc */
            if c-nom-prog-upc-mg97   <> "" and
               c-nom-prog-upc-mg97   <> ?  then do:
            
                  run value( c-nom-prog-upc-mg97  )
                        ( "Unlock_Ped-venda", 
                           input-output table tt-epc
                        ).        
            end.
        end.
    end.
    else do:
        /* upc */
        if c-nom-prog-upc-mg97   <> "" and
           c-nom-prog-upc-mg97   <> ?  then do:
        
              run value( c-nom-prog-upc-mg97  )
                    ( "Unlock_Ped-venda", 
                       input-output table tt-epc
                    ).        
        end.
    end.





/* end_epc_call*/
 
    end.

    if  not avail ped-venda
    and not locked ped-venda then do:
