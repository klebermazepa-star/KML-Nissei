PROCEDURE validaSTASemSaldo:
  /* PROCEDURE validaSTASemSaldo: */
def input  param p-i-seq-wt-docto    like wt-docto.seq-wt-docto no-undo.
def output param p-l-procedimento-ok as log                     no-undo.

def var de-saldo-sta  as decimal   no-undo.
DEF VAR c-lista-itens AS CHAR      NO-UNDO.
DEF VAR h-bodi01102   AS   HANDLE  NO-UNDO.
DEF VAR l-sta-media   AS   LOGICAL NO-UNDO.

if  not avail wt-docto
or  wt-docto.seq-wt-docto <> p-i-seq-wt-docto then do:
   run localizaWtDocto(input  p-i-seq-wt-docto,
                       output l-proc-ok-aux).
   
