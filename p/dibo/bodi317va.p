/*-------------------------------------------------------------------------------------------------------

 Procedimento: validaNrNotaFisSubst

     Objetivo: Validar o campo nr nota fiscal subst

 Parâmetros de Entrada/Saída:
   Entrada: p-c-nr-nota-fis-subst: Número da Nota Fiscal de Substituição.
   Saída..: p-l-procedimento-ok: Retorna que o procedimento ocorreu por completo.
                      

--------------------------------------------------------------------------------------------------------*/

PROCEDURE validaNrNotaFisSubst:
  /* PROCEDURE validaNrNotaFisSubst: */

    def  input  param  p-c-cod-estabel   like  nota-fiscal.cod-estabel  no-undo.
    def  input  param  p-c-serie         like  nota-fiscal.serie        no-undo.
    def  input  param  p-c-nr-nota-fisc  like  nota-fiscal.nr-nota-fis  no-undo.

    DEFINE VARIABLE c-cod-ser-nfse-vinc-rps  AS CHARACTER   NO-UNDO.
    
    /*--- Nota Fiscal de Serviço Eletronica ---*/
    IF  l-integ-nfse           AND
        p-c-nr-nota-fisc <> "" THEN DO:
    
        FOR FIRST nota-fiscal NO-LOCK
            WHERE nota-fiscal.cod-estabel     = p-c-cod-estabel
              AND nota-fiscal.serie           = p-c-serie
              AND nota-fiscal.nr-nota-fis     = p-c-nr-nota-fisc
              AND 
                      INTEGER(SUBSTR(nota-fiscal.char-1,143,2))
                  = 3: /* Convertida */
        END.

        /*Busca nota com a série vinculada */
        FOR FIRST ser-estab NO-LOCK
            WHERE ser-estab.cod-estab = p-c-cod-estabel
              AND ser-estab.serie     = p-c-serie
              AND 
                      SUBSTR(ser-estab.char-1,71,1) = "S":U
                  
              AND (TRIM(SUBSTRING(ser-estab.char-1,295,1)) = "1" /*OR TRIM(SUBSTRING(ser-estab.char-1,295,1)) = ""*/ ): /* Série tipo RPS */

            ASSIGN c-cod-ser-nfse-vinc-rps = TRIM(SUBSTRING(ser-estab.char-1,296,5)). /* Série NFS-e vinculada na Série RPS */
        END.
        IF  c-cod-ser-nfse-vinc-rps <> "":U THEN
            FOR FIRST nota-fiscal NO-LOCK
                WHERE nota-fiscal.cod-estabel     = p-c-cod-estabel
                  AND nota-fiscal.serie           = c-cod-ser-nfse-vinc-rps
                  AND nota-fiscal.nr-nota-fis     = p-c-nr-nota-fisc
                  AND 
                          INTEGER(SUBSTR(nota-fiscal.char-1,143,2))
                      = 3: /* Convertida */
            END.

        IF  NOT AVAIL nota-fiscal THEN
            RETURN "NOK":U.
            
    END.
    
    RETURN "OK".
   
/* END PROCEDURE. */
  /* PROCEDURE validaNrNotaFisSubst: */
END PROCEDURE.


