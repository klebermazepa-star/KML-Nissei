    /*    localizaWtItDocto acessem as tabelas com EXCLUSIVE-LOCK).                                       */
    /*----------------------------------------------------------------------------------------------------*/

    for first wt-it-imposto no-lock
        where wt-it-imposto.seq-wt-docto    = p-i-seq-wt-docto
