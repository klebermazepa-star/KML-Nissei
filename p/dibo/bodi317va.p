/*-------------------------------------------------------------------------------------------------------

 Procedimento: validaQuantidade

     Objetivo: Validar o campo quantidade faturada na unidade do item

 Parâmetros de Entrada/Saída:
   Entrada: p-i-seq-wt-docto...: Sequencia do registro da tabela wt-docto.
            p-i-seq-wt-it-docto: Sequencia do registro da tabela wt-it-docto.
   Saída..: p-l-procedimento-ok: Retorna que o procedimento ocorreu por completo.
                      

--------------------------------------------------------------------------------------------------------*/

PROCEDURE validaQuantidade:
  
/*PROCEDURE validaQuantidade:*/
    /* Definição dos parâmetros de Entrada/Saída */
    def input  param p-i-seq-wt-docto    like wt-docto.seq-wt-docto       no-undo.
    def input  param p-i-seq-wt-it-docto like wt-it-docto.seq-wt-it-docto no-undo.
    def output param p-l-procedimento-ok as   log                         no-undo.

    /* Definicao de variaveis locais */
    def var de-qt-maior         like ped-ent.qt-atendida    no-undo. 
    def var de-qt-cham          like ped-item.qt-pedida     no-undo. 
    def var de-qt-saldo-aberto  like ped-ent.qt-atendida    no-undo.
    def var de-dif              like ped-item.qt-pedida     no-undo.
    def var h-boin672           as   handle. /* ATENÇÃO NÃO COLOCAR NO-UNDO NA DEFINIÇÃO DO HANDLE */
    DEF VAR h-api               AS   HANDLE.
    def var de-qtd-devol        as   decimal                no-undo.
    DEF VAR de-qt-devolvida     AS   DECIMAL                NO-UNDO.
    DEF VAR lLogControlCham     AS   LOGICAL                NO-UNDO.
    DEF VAR de-qt-faturada      LIKE ped-ent.qt-pedida      NO-UNDO.    
    DEF VAR de-qt-pedida        LIKE ped-ent.qt-pedida      NO-UNDO.    
    DEF VAR de-qt-proc          LIKE ped-ent.qt-pedida      NO-UNDO.
    DEF VAR de-qt-atendida      AS   DECIMAL                NO-UNDO.
    DEF VAR h-bocx195           AS   HANDLE                 NO-UNDO.
    DEF VAR c-return            AS   CHAR                   NO-UNDO.
    DEF VAR de-perc-fat-ped     AS   DEC INITIAL 0          NO-UNDO.

    assign c-ultimo-metodo-exec = replace(program-name(1)," ":U, "~~":U).

    /* início da leitura das tabelas necessárias */

    if  not avail wt-it-docto
    or  wt-it-docto.seq-wt-docto    <> p-i-seq-wt-docto
    or  wt-it-docto.seq-wt-it-docto <> p-i-seq-wt-it-docto then do:
        run localizaWtItDocto(input  p-i-seq-wt-docto,
                              input  p-i-seq-wt-it-docto,
                              output l-proc-ok-aux).
        
/*--------------------------------------------------------------------------
    Library    : bodi317.i5
    Purpose    : Include que possui a chamada para a procedure que trata o 
                 retorno dos erros.

    Parameters :

    Notes      :
  ------------------------------------------------------------------------*/

run trataErros(input l-proc-ok-aux, input " ", input ?).
if  not l-proc-ok-aux then return.

/*  BODI317.I5  */
 
    end.

    if  not avail user-coml
    or  user-coml.usuario <> c-seg-usuario then
        for first user-coml
            fields (user-coml.usuario
                                user-coml.ind-arredon-lote
                                user-coml.nat-incons) 
            where user-coml.usuario = c-seg-usuario no-lock:
        end.

    ASSIGN lLogControlCham = NO.

    /* fim da leitura das tabelas necessárias */

    if  wt-docto.nr-pedcli <> "":U  
    and not(    i-pais-impto-usuario = 1 /* Brasil */
            and lookup(string(wt-docto.ind-tip-nota),"3,51,52,54":U) > 0) /* Diferente de diferença de preço */
    and not(    i-pais-impto-usuario <> 1 /* Nao considera Nota de Credito/Debito Internacional */
            and (   wt-docto.ind-tip-nota = 3 
                 or wt-docto.ind-tip-nota = 4)) then do:

        if  not avail emitente
        or  emitente.nome-abrev <> wt-docto.nome-abrev then do:
            run localizaEmitente(input  0,
                                 input  wt-docto.nome-abrev,
                                 output l-proc-ok-aux).
            
/*--------------------------------------------------------------------------
    Library    : bodi317.i5
    Purpose    : Include que possui a chamada para a procedure que trata o 
                 retorno dos erros.

    Parameters :

    Notes      :
  ------------------------------------------------------------------------*/

run trataErros(input l-proc-ok-aux, input " ", input ?).
if  not l-proc-ok-aux then return.

/*  BODI317.I5  */
 
        end.

        if  not avail ped-venda
        or  ped-venda.nome-abrev <> wt-docto.nome-abrev
        or  ped-venda.nr-pedcli  <> wt-it-docto.nr-pedcli then do:
            run localizaPedVenda(input  wt-docto.nome-abrev,
                                 input  wt-it-docto.nr-pedcli,
                                 output l-proc-ok-aux).
            
/*--------------------------------------------------------------------------
    Library    : bodi317.i5
    Purpose    : Include que possui a chamada para a procedure que trata o 
                 retorno dos erros.

    Parameters :

    Notes      :
  ------------------------------------------------------------------------*/

run trataErros(input l-proc-ok-aux, input " ", input ?).
if  not l-proc-ok-aux then return.

/*  BODI317.I5  */
 
        end.

        for first ped-item
            fields (ped-item.per-minfat des-un-medida) no-lock
            where ped-item.nome-abrev   = wt-docto.nome-abrev
            and   ped-item.nr-pedcli    = wt-it-docto.nr-pedcli
            and   ped-item.nr-sequencia = wt-it-docto.nr-sequencia
            and   ped-item.it-codigo    = wt-it-docto.it-codigo:
        end.
            

        for first ped-ent
            fields (ped-ent.nr-entrega
                    ped-ent.cod-refer 
                    ped-ent.it-codigo 
                    ped-ent.nr-sequencia 
                    ped-ent.nr-pedcli 
                    ped-ent.nome-abrev 
                    ped-ent.qt-pedida 
                    ped-ent.tipo-atend 
                    ped-ent.qt-atendida ped-ent.qt-un-fat ) no-lock             
            where ped-ent.nome-abrev   = wt-docto.nome-abrev
            and   ped-ent.nr-pedcli    = wt-it-docto.nr-pedcli
            and   ped-ent.nr-sequencia = wt-it-docto.nr-sequencia
            and   ped-ent.it-codigo    = wt-it-docto.it-codigo
            and   ped-ent.nr-entrega   = wt-it-docto.nr-entrega:
        end.
    

        if  avail ped-ent then do:

            
                ASSIGN de-qt-faturada = wt-it-docto.quantidade[2]              
                       de-qt-proc    = ped-ent.qt-un-fat.
            
            
            ASSIGN de-qt-pedida   = ped-ent.qt-pedida
                   de-qt-atendida = ped-ent.qt-atendida.

            
                FIND FIRST param-global NO-LOCK NO-ERROR.
                IF param-global.modulo-ex  = YES AND
                   wt-docto.nr-proc-exp <> ""    AND
                   emitente.natureza       = 3   OR 
                   emitente.natureza       = 4   THEN DO:
                   
                    IF NOT VALID-HANDLE(h-bocx195) THEN
                        RUN cxbo/bocx195.p PERSISTENT SET h-bocx195.
                                        
                    RUN findPk_proc_pedent IN h-bocx195 (INPUT 
                                                                   
                                                                        wt-docto.cod-estab-proces-export,
                                                                   
                                                               
                                                         INPUT  wt-docto.nr-proc-exp, 
                                                         INPUT  wt-docto.nome-abrev, 
                                                         INPUT  wt-it-docto.nr-pedcli, 
                                                         INPUT  wt-it-docto.nr-sequencia, 
                                                         INPUT  wt-it-docto.it-codigo, 
                                                         INPUT  wt-it-docto.cod-refer, 
                                                         INPUT  wt-it-docto.nr-entrega,
                                                         OUTPUT c-return).

                    IF c-return = "" THEN DO:
                        
                            ASSIGN de-qt-faturada = wt-it-docto.quantidade[2].
                        
                        
                        RUN getDecField IN h-bocx195(INPUT "quantidade[1]", OUTPUT de-qt-proc).
                        RUN getDecField IN h-bocx195(INPUT "quantidade[1]", OUTPUT de-qt-pedida).

                        RUN calculaQuantidadeAtendida IN h-bocx195(INPUT  
                                                                              
                                                                                  wt-docto.cod-estab-proces-export,
                                                                              
                                                                          
                                                                   INPUT  wt-docto.nr-proc-exp,  
                                                                   INPUT  ped-ent.nome-abrev,  
                                                                   INPUT  ped-ent.nr-pedcli,    
                                                                   INPUT  ped-ent.nr-sequencia, 
                                                                   INPUT  ped-ent.it-codigo,    
                                                                   INPUT  ped-ent.cod-refer,    
                                                                   INPUT  ped-ent.nr-entrega,   
                                                                   OUTPUT de-qt-atendida).
                    END.
                END.
    
                IF VALID-HANDLE(h-bocx195) THEN DO:
                    DELETE PROCEDURE h-bocx195.
                    ASSIGN h-bocx195 = ?.
                END.
                
            
            ASSIGN de-perc-fat-ped = emitente.perc-fat-ped.

            if  AVAIL emitente
            AND substring(emitente.char-1,147,1) = "S" THEN
                FOR first item-cli no-lock
                    where item-cli.it-codigo    = wt-it-docto.it-codigo
                      AND item-cli.nome-abrev   = wt-docto.nome-abrev 
                      and item-cli.unid-med-cli = ped-item.des-un-medida :
                    ASSIGN de-perc-fat-ped = item-cli.int-1.
                END.

            /*** Consistir percentual de faturamento a maior por pedido ***/
            assign de-qt-maior        = trunc(de-qt-pedida * de-perc-fat-ped / 100, 4)
                   de-qt-saldo-aberto = de-qt-pedida - de-qt-atendida.   

            if  wt-it-docto.quantidade[1] > (de-qt-maior + de-qt-saldo-aberto) then do:
                /* MENSAGEM: 5602 - Quantidade atendida excede quantidade pedida */
                
                
                     if  can-find(first funcao
                                  where funcao.cd-funcao = 'spp-sgt':U
                                  and   funcao.ativo     = true) then do:
                        /* 

Grava no clientlog uma linha contendo o nome da funþao
e se ela esta ativa ou nao e qual arquivo a chamou

