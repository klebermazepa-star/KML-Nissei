PROCEDURE validaDescMeiodePagamento:

     DEFINE INPUT  PARAM i-seq-wt-docto  AS INT NO-UNDO.
     DEFINE OUTPUT PARAM l-proc-ok-aux   AS LOG NO-UNDO INITIAL YES.

     DEFINE VAR c-chave-busca AS CHAR NO-UNDO.

     FIND FIRST b-wt-docto
         WHERE  b-wt-docto.seq-wt-docto = i-seq-wt-docto NO-LOCK NO-ERROR.
         
     IF AVAIL b-wt-docto THEN DO:
         ASSIGN c-chave-busca = TRIM(STRING(ABS(b-wt-docto.seq-wt-docto))).
         
         IF  b-wt-docto.cdd-embarq <> 0 THEN
             ASSIGN c-chave-busca = TRIM(c-chave-busca + CHR(2) + TRIM(b-wt-docto.nr-pedcli)).
     
         FOR EACH  b-nota-fisc-adc 
             WHERE b-nota-fisc-adc.cod-estab        = b-wt-docto.cod-estabel   
               AND b-nota-fisc-adc.cod-serie        = b-wt-docto.serie         
               AND b-nota-fisc-adc.cod-nota-fisc    = c-chave-busca 
               AND b-nota-fisc-adc.cdn-emitente     = b-wt-docto.cod-emitente 
               AND b-nota-fisc-adc.cod-natur-operac = b-wt-docto.nat-operacao 
               AND b-nota-fisc-adc.idi-tip-dado     = 30 NO-LOCK:
               
             IF  b-nota-fisc-adc.num-seq     = 99 /* Outros */
             AND b-nota-fisc-adc.cod-livre-1 = "" THEN 
                 ASSIGN l-proc-ok-aux = NO.
         END.    
     END.
END.

