/*-------------------------------------------------------------------------------------------------------

 Procedimento: validaBonif

     Objetivo: Validar as Bonfica╗äes de acordo com os par│metros do cadastro de clientes.

 Par│metros de Entrada/Sa¡da:
   Entrada: p-i-seq-wt-docto...: Chave principal do registro da tabela wt-docto.
   Sa¡da..: p-l-procedimento-ok: Retorna que o procedimento ocorreu por completo.
                      

--------------------------------------------------------------------------------------------------------*/

PROCEDURE validaBonif:
  /*PROCEDURE validaBonif:*/
    /* Defini╗Æo dos par│metros de Entrada/Sa¡da */
    def input  param p-c-nr-pedcli       as char                    no-undo.
    def input  param p-c-nome-abrev      as char                    no-undo.
    def input  param p-de-cdd-embarq     as dec                     no-undo.
    def output param p-l-procedimento-ok as log                     no-undo.

    assign c-ultimo-metodo-exec = replace(program-name(1)," ":U, "~~":U).

    def buffer b-ped-venda-bonif for ped-venda.
    def buffer b-wt-docto-bonif  for wt-docto.

    /******************************************************************************************************
      - dist-emitente.log-fatur-ped-bonif:  fatura bonificação somente se a venda for atendida totalmente 
      - dist-emitente.log-libera-venda-sem-bonif: fatura venda sem o pedido de bonificação 
    ******************************************************************************************************/

    /*** Descontos e Bonificações ***/
    if not avail param-global then find first param-global no-lock.    

    if  param-global.modulo-09 then do:

        if  not avail emitente
        or  emitente.nome-abrev <> p-c-nome-abrev then 
            find first emitente 
                 where emitente.nome-abrev = p-c-nome-abrev no-lock no-error.
        
        find first dist-emitente 
             where dist-emitente.cod-emitente = emitente.cod-emitente no-lock no-error.

        if  avail dist-emitente
        and (  dist-emitente.log-fatur-ped-bonif 
            or not dist-emitente.log-libera-venda-sem-bonif) then do:
            
            find first ped-venda
                 where ped-venda.nome-abrev = emitente.nome-abrev
                 and   ped-venda.nr-pedcli  = p-c-nr-pedcli no-lock no-error.
                 
            if  avail ped-venda then do:            
   
                /* TRATAMENTO PARA NOTAS FISCAIS COM EMBARQUE */
                if  p-de-cdd-embarq <> 0 then
                
                    /* pedido de bonificacao */
                    if  ped-venda.num-pedido-orig <> "":U then 
                        /* acessando o pedido de venda relacionado ao pedido de bonificacao */
                        for first b-ped-venda-bonif no-lock
                            where b-ped-venda-bonif.nome-abrev  = ped-venda.nome-abrev
                            and   b-ped-venda-bonif.nr-pedcli   = ped-venda.num-pedido-orig 
                            and   b-ped-venda-bonif.cod-sit-ped < 3:
    
                            /* verifica se existe um wt-docto referente a venda do pedido de bonificação */
                            if  not can-find(first b-wt-docto-bonif
                                             where b-wt-docto-bonif.cdd-embarq   = p-de-cdd-embarq
                                             and   b-wt-docto-bonif.nome-abrev   = b-ped-venda-bonif.nome-abrev
                                             and   b-wt-docto-bonif.nr-pedcli    = b-ped-venda-bonif.nr-pedcli
                                             and   b-wt-docto-bonif.selecionado  = "*")
                            and not can-find(first pre-fatur /* se junta pedidos cai aqui */
                                             where pre-fatur.cdd-embarq   = p-de-cdd-embarq
                                             and   pre-fatur.nr-resumo    = wt-docto.nr-resumo
                                             and   pre-fatur.nome-abrev   = b-ped-venda-bonif.nome-abrev
                                             and   pre-fatur.nr-pedcli    = b-ped-venda-bonif.nr-pedcli) then do:
        
                                /* O cliente está parametrizado para faturar a bonificação somente após o faturamento total da venda. */           
                                
