/*-------------------------------------------------------------------------------------------------------

Procedimento: validaSaldoOrdensProducao

   Objetivo: Validar as informa╗äes ref. as quantidades alocadas de ordens de produ╗Æo.

Par│metros de Entrada/Sa¡da:
 Entrada: p-i-seq-wt-docto...: Chave principal do registro da tabela wt-docto.
 Sa­da..: p-l-procedimento-ok: Retorna que o procedimento ocorreu por completo.


--------------------------------------------------------------------------------------------------------*/

PROCEDURE retornaResumoPossuiOrdem:
/*PROCEDURE retornaResumoPossuiOrdem:*/
    /* Definição dos par│metros de Entrada/Sa¡da */
    def input  param p-cdd-embarq        like res-cli.cdd-embarq         no-undo.
    def input  param p-nr-resumo         like res-cli.nr-resumo          no-undo.
    def input  param p-nome-abrev        like res-cli.nome-abrev         no-undo.
    def output param p-l-possui-ordem    as logical                      no-undo.
    def output param p-l-procedimento-ok as log                          no-undo.

    def var c-ultimo-metodo-exec as char no-undo.
    def var l-possui-ordem       as log  no-undo.
      
    assign c-ultimo-metodo-exec = replace(program-name(1)," ":U, "~~":U).

  
    /* verifica se algum item do embarque possui quantidade alocada em 
       ordens de produção - l-possui-ordem retorna yes */
    /***************************************************************************
**
**  FT3000.i1 -Verifica se o item possui alocação em ordens de produção 
**
**  Parâmetros: Entradas: {1} cdd-embarq
**                        {2} nr-resumo
**                        {3} nome-abrev
*****************************************************************************/    

    FOR EACH  it-pre-fat NO-LOCK
        WHERE it-pre-fat.cdd-embarq   = p-cdd-embarq
        AND   it-pre-fat.nr-resumo    = p-nr-resumo
        AND   it-pre-fat.nome-abrev   = p-nome-abrev :

        if  can-find(first ped-ent
                 where ped-ent.nome-abrev   = it-pre-fat.nome-abrev
                 and   ped-ent.nr-pedcli    = it-pre-fat.nr-pedcli
                 and   ped-ent.nr-sequencia = it-pre-fat.nr-sequencia
                 and   ped-ent.it-codigo    = it-pre-fat.it-codigo
                 and   ped-ent.cod-refer    = it-pre-fat.cod-refer
                 and   ped-ent.nr-entrega   = it-pre-fat.nr-entrega
             /*EMS 2.06*/
                 and   (ped-ent.qtd-aloc-op - ped-ent.qtd-reporta-op-ped) > 0) then do:
             
                 assign l-possui-ordem = yes.
                 leave.
        end.
    END.

 

    if  c-nom-prog-upc-mg97  <> "":U then  do:
    
        FOR EACH tt-epc: DELETE tt-epc. END.
        
        CREATE tt-epc.
        ASSIGN tt-epc.cod-event     = "afterPossuiOrdem":U
               tt-epc.cod-parameter = "Value_init_l-possui-ordem":U
               tt-epc.val-parameter = STRING(l-possui-ordem, "yes/no":U).
            
        CREATE tt-epc.
        ASSIGN tt-epc.cod-event     = "afterPossuiOrdem":U
               tt-epc.cod-parameter = "Value_p-cdd-embarq":U
               tt-epc.val-parameter = STRING(p-cdd-embarq).
                
        CREATE tt-epc.
        ASSIGN tt-epc.cod-event     = "afterPossuiOrdem":U
               tt-epc.cod-parameter = "Value_p-nr-resumo":U
               tt-epc.val-parameter = STRING(p-nr-resumo).
        
        /***************************************************************
**
** I-EPC201.I - Padroniza a chamada dos programas de integraþÒo/
**              customizaþÒo.
**
** {1}        - ind-event
**
***************************************************************/ 

/* begin_epc_call*/

/* DPC */
if c-nom-prog-dpc-mg97  <> "" and
   c-nom-prog-dpc-mg97  <> ?  then do:

   run value( c-nom-prog-dpc-mg97  ) 
            ( "afterPossuiOrdem", 
              input-output table tt-epc
            ).
end.                                     

/* APPC */
if c-nom-prog-appc-mg97  <> "" and
   c-nom-prog-appc-mg97  <> ?  then do:

   run value( c-nom-prog-appc-mg97  ) 
            ( "afterPossuiOrdem", 
              input-output table tt-epc
            ).
end.                                     

/**************************************************
** Controle de UPC por Evento
**************************************************/
/* Se o programa possuir a definicação da include/epc-mft-200.i */
    if can-find(first control-upc-prog
                where control-upc-prog.cod-prog-dtsul = 'BODI317VA'
                  and control-upc-prog.log-ativo) then do: /* Se o programa estiver cadastrado e ativo, deve-se verificar os eventos cadastrados para ele */
        if can-find(first control-upc-evento 
                        where control-upc-evento.cod-prog-dtsul = 'BODI317VA'
                      and control-upc-evento.cod-evento = "afterPossuiOrdem"
                              and control-upc-evento.log-ativo) then do: /* O evento só deve ser executado se estiver cadastrado e ativo */
            
            /* upc */
            if c-nom-prog-upc-mg97   <> "" and
               c-nom-prog-upc-mg97   <> ?  then do:
            
                  run value( c-nom-prog-upc-mg97  )
                        ( "afterPossuiOrdem", 
                           input-output table tt-epc
                        ).        
            end.
        end.
    end.
    else do:
        /* upc */
        if c-nom-prog-upc-mg97   <> "" and
           c-nom-prog-upc-mg97   <> ?  then do:
        
              run value( c-nom-prog-upc-mg97  )
                    ( "afterPossuiOrdem", 
                       input-output table tt-epc
                    ).        
        end.
    end.





/* end_epc_call*/
 
        
        ASSIGN l-possui-ordem = CAN-FIND(FIRST tt-epc
                                         WHERE tt-epc.cod-event     = "afterPossuiOrdem":U
                                         AND   tt-epc.cod-parameter = "Value_init_l-possui-ordem":U
                                         AND   tt-epc.val-parameter = "yes":U).
    END.

