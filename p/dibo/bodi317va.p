/*-------------------------------------------------------------------------------------------------------

 Procedimento: validaLocalRetiradaNota
               validaLocalRetiradaNotaEmbarque
               validaMaisDeUmDepositoExterno
               validaMaisDeUmDepositoExternoEmbarque

     Objetivo: Validar informacoes referentes ao local de retirada do deposito externo

 Parâmetros de Entrada/Saída:
   Entrada: wt-docto.seq-wt-docto


--------------------------------------------------------------------------------------------------------*/
PROCEDURE validaLocalRetiradaNota:
    DEFINE INPUT PARAM i-seq-wt-docto           AS INT NO-UNDO.
    DEFINE OUTPUT PARAM l-local-retirada-valido AS LOG NO-UNDO INITIAL YES.
    
    FIND FIRST b-wt-docto
         WHERE b-wt-docto.seq-wt-docto = i-seq-wt-docto NO-LOCK NO-ERROR.
    
    FOR EACH wt-fat-ser-lote
       WHERE wt-fat-ser-lote.seq-wt-docto = b-wt-docto.seq-wt-docto NO-LOCK:
 
        FOR FIRST b-deposito      NO-LOCK
            WHERE b-deposito.cod-depos    = wt-fat-ser-lote.cod-depos AND 
                  b-deposito.ind-tipo-dep = 2, 
            FIRST b-emitente      NO-LOCK
            WHERE b-emitente.nome-abrev = b-deposito.nome-abrev ,
            FIRST b-dist-emitente NO-LOCK
            WHERE b-dist-emitente.cod-emitente = b-emitente.cod-emitente AND
                  b-dist-emitente.cod-dep-ext  = b-deposito.cod-depos:

                    FIND FIRST b-nota-fisc-adc 
                         WHERE b-nota-fisc-adc.cod-estab        = b-wt-docto.cod-estabel   
                           AND b-nota-fisc-adc.cod-serie        = b-wt-docto.serie         
                           AND b-nota-fisc-adc.cod-nota-fisc    = STRING(b-wt-docto.seq-wt-docto)
                           AND b-nota-fisc-adc.cdn-emitente     = b-wt-docto.cod-emitente 
                           AND b-nota-fisc-adc.cod-natur-operac = b-wt-docto.nat-operacao 
                           AND b-nota-fisc-adc.idi-tip-dado     = 32 
                           AND b-nota-fisc-adc.num-seq          = 1 NO-LOCK NO-ERROR.
                   
                   IF AVAIL b-nota-fisc-adc THEN 
                      IF  ENTRY(1,b-nota-fisc-adc.cod-livre-1,CHR(2)) = "" AND 
                          ENTRY(2,b-nota-fisc-adc.cod-livre-1,CHR(2)) = "" THEN
                          ASSIGN l-local-retirada-valido = NO.
        END. /* for first */
    END. /* for each wt-fat-ser-lote */
END.

PROCEDURE validaLocalRetiradaNotaEmbarque:
    DEFINE INPUT  PARAM d-cdd-embarq             AS DECIMAL   NO-UNDO.
    DEFINE OUTPUT PARAM l-local-retirada-valido  AS LOG NO-UNDO INITIAL YES.
    
    FOR EACH b-wt-docto
       WHERE b-wt-docto.cdd-embar   = d-cdd-embarq NO-LOCK:
    
        IF AVAIL b-wt-docto THEN DO:
            FIND FIRST b-nota-fisc-adc 
                 WHERE b-nota-fisc-adc.cod-estab        = b-wt-docto.cod-estabel   
                   AND b-nota-fisc-adc.cod-serie        = b-wt-docto.serie         
                   AND b-nota-fisc-adc.cod-nota-fisc    = STRING(b-wt-docto.seq-wt-docto)
                   AND b-nota-fisc-adc.cdn-emitente     = b-wt-docto.cod-emitente 
                   AND b-nota-fisc-adc.cod-natur-operac = b-wt-docto.nat-operacao 
                   AND b-nota-fisc-adc.idi-tip-dado     = 32 
                   AND b-nota-fisc-adc.num-seq          = 1 NO-LOCK NO-ERROR.
           
           IF AVAIL b-nota-fisc-adc AND 
              ENTRY(1,b-nota-fisc-adc.cod-livre-1,CHR(2)) = "" AND 
              ENTRY(2,b-nota-fisc-adc.cod-livre-1,CHR(2)) = "" THEN
                  ASSIGN l-local-retirada-valido = NO.       
        END.
    END. 
END.

PROCEDURE validaDepositoFechado:
    DEFINE INPUT  PARAM i-seq-wt-docto            AS INT NO-UNDO.
    DEFINE OUTPUT PARAM l-deposito-fechado-valido AS LOG NO-UNDO INITIAL YES.
    DEFINE OUTPUT PARAM c-emitente-deposito       AS CHAR NO-UNDO.
    DEFINE OUTPUT PARAM c-deposito-fechado        AS CHAR NO-UNDO.
    
    FOR EACH wt-fat-ser-lote
       WHERE wt-fat-ser-lote.seq-wt-docto = i-seq-wt-docto:
         
         FOR FIRST b-deposito      NO-LOCK
             WHERE b-deposito.cod-depos    = wt-fat-ser-lote.cod-depos AND 
                   b-deposito.ind-tipo-dep = 2, 
             FIRST b-emitente      NO-LOCK
             WHERE b-emitente.nome-abrev = b-deposito.nome-abrev:
             
             FIND FIRST b-dist-emitente NO-LOCK
                  WHERE b-dist-emitente.cod-emitente = b-emitente.cod-emitente AND
                        b-dist-emitente.cod-dep-ext  = b-deposito.cod-depos NO-ERROR.
                        
             IF AVAIL b-dist-emitente THEN
                ASSIGN l-deposito-fechado-valido = YES.
             ELSE 
                ASSIGN l-deposito-fechado-valido = NO
                       c-emitente-deposito       = b-deposito.nome-abrev
                       c-deposito-fechado        = b-deposito.cod-depos.
        END. /* for first */
    END. /* for each */
END.

