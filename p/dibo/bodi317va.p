    IF  SUBSTRING(natur-oper.char-1,1,5) = "0" THEN /* Entrega Futura */
        ASSIGN l-remessa-ent-futura = YES.
        
END.   



 

            l-nat-oper-diferente = NO.
            IF l-fatura-fat-antecip-nota <> l-fatura-fat-antecip THEN
                ASSIGN l-nat-oper-diferente = YES.
            ELSE IF l-remessa-fat-antecip-nota <> l-remessa-fat-antecip THEN
                ASSIGN l-nat-oper-diferente = YES.
            ELSE IF l-fatura-ent-futura-nota <> l-fatura-ent-futura THEN
                ASSIGN l-nat-oper-diferente = YES.
