                                               else p-c-un )
                 no-lock no-error.
    
        if available tab-conv-un then do:
            assign de-indice = tab-conv-un.fator-conver /
                               if tab-conv-un.num-casa-dec = 0 then 1
                               else exp(10,tab-conv-un.num-casa-dec). 
        end.
        else 
            assign de-indice = 1.
    
    end.
