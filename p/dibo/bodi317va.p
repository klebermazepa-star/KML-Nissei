                            AND   componente.cod-refer    = saldo-terc.cod-refer   
                            AND   componente.seq-comp     = saldo-terc.sequencia NO-LOCK:
                            IF  componente.componente = 1 THEN 
                                /* Diminui a quantidade de produtos que já foram enviados */
                                ASSIGN de-qt-saldo = de-qt-saldo - componente.quantidade.
                            ELSE
                                /* Aumenta a quantidade de produtos que foram devolvidos */
