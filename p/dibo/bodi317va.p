    assign c-ultimo-metodo-exec = replace(program-name(1)," ":U, "~~":U).

    /* Definição de variáveis locais */
    def var de-tot-merc-liq as dec no-undo.
    def var de-tot-merc-ori as dec no-undo.
    def var de-tot-tab-pre  as dec no-undo.


    /*-------- UPC Valida Orçamento Fat Balcão ---------*/
    IF  c-nom-prog-dpc-mg97  <> "" OR  
        c-nom-prog-appc-mg97 <> "" OR  
        c-nom-prog-upc-mg97  <> "" THEN 
    DO:
        empty temp-table tt-epc.

        /********************************************************************************
