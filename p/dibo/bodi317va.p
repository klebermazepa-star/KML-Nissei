PROCEDURE validaNrEmbarque:
  /*PROCEDURE validaNrEmbarque:*/
    /* Definição dos parâmetros de Entrada/Saída */
    def input  param p-de-cdd-embarq       like wt-docto.cdd-embarq   no-undo.
    def output param p-l-procedimento-ok  as   log                   no-undo.
    
    define variable cDesc as char no-undo.

    assign c-ultimo-metodo-exec = replace(program-name(1)," ":U, "~~":U).

        IF CAN-FIND(FIRST funcao NO-LOCK
                    WHERE funcao.cd-funcao = "SPP-NEOLOG":U 
                      AND funcao.ativo) THEN DO:
                /* 

Grava no clientlog uma linha contendo o nome da funþao
e se ela esta ativa ou nao e qual arquivo a chamou

*/
IF LOG-MANAGER:LOGGING-LEVEL > 2 THEN
    LOG-MANAGER:WRITE-MESSAGE("SPP-NEOLOG" + " | " + STRING(YES) + " | " + "bodi317va.m38", "CD7070") NO-ERROR.

/* 

grava no extrato de versao uma linha contendo o nome da funþao
e se ela esta ativa ou nao e qual arquivo a chamou

*/
IF c-arquivo-log <> "" AND c-arquivo-log <> ? THEN DO:
    OUTPUT TO VALUE(c-arquivo-log) APPEND.
         PUT UNFORMATTED "CD7070 | " + "SPP-NEOLOG" + " | " + STRING(YES) + " | " + "bodi317va.m38" SKIP.
    OUTPUT CLOSE.
END. 
 
        
            FIND FIRST embarque NO-LOCK
                 WHERE embarque.cdd-embarq = p-de-cdd-embarq NO-ERROR.
                         
            /* Situação do embarque:  1 - Envio OK; 2 - Erro Envio; 3 - Em Otimização */            
            IF AVAIL embarque AND (embarque.int-2 = 1 OR embarque.int-2 = 2 OR embarque.int-2 = 3) AND embarque.identific <> "neolog" THEN DO:
            
               CASE embarque.int-2:
                   WHEN 0 THEN ASSIGN cDesc = "Não Otimiza".
                   WHEN 1 THEN ASSIGN cDesc = "Envio OK".   
                   WHEN 2 THEN ASSIGN cDesc = "Erro Envio". 
                   WHEN 3 THEN ASSIGN cDesc = "Em Otimização". 
                   WHEN 4 THEN ASSIGN cDesc = "Desbloqueado".   
               END CASE.        
               
               /* FT0307 - REALIZA OTIMIZAÇÃO DA CARGA */
               FOR FIRST tipo-emb NO-LOCK
                   WHERE tipo-emb.cod-tipo = embarque.cod-tipo
                     AND SUBSTRING(tipo-emb.char-1,1,1) = "Y":
                     
