PROCEDURE validaQtFaturamentoAntecipado:
  /*PROCEDURE validaQtFaturamentoAntecipado: */

    /* Definição dos parametros de Entrada/Saída */
    DEF INPUT  PARAM p-c-cod-emitente     LIKE wt-docto.cod-emitente       NO-UNDO.                                            
    DEF INPUT  PARAM p-c-cod-estabel      LIKE wt-docto.cod-estabel        NO-UNDO.
    DEF INPUT  PARAM p-c-nr-nota-fis      LIKE wt-docto.nr-nota-ent-fut    NO-UNDO.
    DEF INPUT  PARAM p-c-serie            LIKE wt-docto.serie-ent-fut      NO-UNDO.
    DEF INPUT  PARAM p-c-nat-operacao     LIKE wt-it-docto.nat-operacao    NO-UNDO.
    DEF INPUT  PARAM p-c-it-codigo        LIKE wt-it-docto.it-codigo       NO-UNDO.
    DEF INPUT  PARAM p-c-cod-refer        LIKE wt-it-docto.cod-refer       NO-UNDO.
    DEF INPUT  PARAM p-i-sequencia        LIKE wt-it-docto.nr-sequencia    NO-UNDO.
    DEF INPUT  PARAM p-de-quantidade-atu  AS DECIMAL                       NO-UNDO.
    DEF OUTPUT PARAM p-l-procedimento-ok  AS LOGICAL                       NO-UNDO.

    DEF VAR c-nat-oper LIKE wt-it-docto.nat-operacao.
    DEF VAR vValidaFatAntecip AS LOGICAL NO-UNDO.

    ASSIGN c-ultimo-metodo-exec = replace(program-name(1)," ":U, "~~":U).

    FOR FIRST nota-fiscal
        WHERE nota-fiscal.cod-estabel = p-c-cod-estabel
          AND nota-fiscal.nr-nota-fis = p-c-nr-nota-fis
          AND nota-fiscal.serie       = p-c-serie NO-LOCK:
        ASSIGN c-nat-oper = nota-fiscal.nat-operacao.
    END.
 
    
        FOR FIRST sdo-fatur-antecip
            WHERE sdo-fatur-antecip.cod-emitente = p-c-cod-emitente
              AND sdo-fatur-antecip.cod-estabel  = p-c-cod-estabel
              AND sdo-fatur-antecip.nr-nota-fis  = p-c-nr-nota-fis
              AND sdo-fatur-antecip.serie        = p-c-serie
              AND sdo-fatur-antecip.nat-operacao = c-nat-oper
              AND sdo-fatur-antecip.it-codigo    = p-c-it-codigo
              AND sdo-fatur-antecip.cod-refer    = p-c-cod-refer
              AND sdo-fatur-antecip.num-seq      = p-i-sequencia EXCLUSIVE-LOCK:
              
            IF  p-de-quantidade-atu > sdo-fatur-antecip.qtd-saldo THEN DO:
