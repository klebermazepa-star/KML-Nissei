                        ASSIGN de-qt-saldo = saldo-terc.quantidade
                               l-possui-saldo-item = NO.
                        FOR EACH  componente
                            WHERE componente.cod-emitente = saldo-terc.cod-emitente 
                            AND   componente.nro-comp     = saldo-terc.nro-docto    
