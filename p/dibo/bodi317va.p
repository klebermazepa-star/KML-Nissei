       l-remessa-fat-antecip = NO
       l-fatura-ent-futura   = NO
       l-remessa-ent-futura  = NO.

IF  natur-oper.ind-entfut AND NOT natur-oper.ind-est-qtd THEN DO: /* eh fatura e nao eh remessa */
    
    IF  SUBSTRING(natur-oper.char-1,1,5) = "1" THEN  /* Faturamento Antecipado */
        ASSIGN l-fatura-fat-antecip = YES.
        
