--------------------------------------------------------------------------------------------------------*/

PROCEDURE validaNrProcExp:
 
/*PROCEDURE validaNrProcExp:*/
    /* Definição dos parâmetros de Entrada/Saída */
    def input  param p-i-seq-wt-docto    like wt-docto.seq-wt-docto       no-undo.
    def output param p-l-procedimento-ok as   log                         no-undo.

    if l-valida-exp then do:

       /* Variaveis locais */
       def var c-cod-dep-ext    like pre-fatur.cod-dep-ext no-undo.
       def var h-bocx185        as handle. /* ATENÇÃO NÃO COLOCAR NO-UNDO NA DEFINIÇÃO DO HANDLE */
       def var h-bocx180        as handle. /* ATENÇÃO NÃO COLOCAR NO-UNDO NA DEFINIÇÃO DO HANDLE */
       def var c-return         as char                    no-undo.
       def var i-value          as integer                 no-undo.
       def var c-char-1         as char format "x(100)"    no-undo.
       def var i-rs-faturamento as int                     no-undo.
       def var i-cod-sit-proc   as int                     no-undo.
       def var i-cod-emitente   as int                     no-undo.
       def var h-bocx195        as handle                  no-undo.
       def var c-nr-proc-exp    as char                    no-undo. 
       def var i-cod-importador as int                     no-undo.
       def var l-emit-duplic    as log                     no-undo.
       def var l-verif-nat      as log                     no-undo.
       def var c-cod-estabel    as char                    no-undo.
       def var c-lbl-situacao-processo                AS CHARACTER NO-UNDO.
       def var c-lbl-emissao-nf-dif-preco             AS CHARACTER NO-UNDO.
       def var c-lbl-liter-processo-de-exportacao     AS CHARACTER NO-UNDO.
       def var c-lbl-liter-faturamento                AS CHARACTER NO-UNDO.
       def var c-lbl-liter-do-processo-de-exportacao  AS CHARACTER NO-UNDO.
       def var c-lbl-inserr-do-processo-de-exportacao AS CHARACTER NO-UNDO.
       def var c-lbl-emitente-nota                    AS CHARACTER NO-UNDO.
       def var c-lbl-emitente-proc-exp                AS CHARACTER NO-UNDO.
       
       assign c-ultimo-metodo-exec = replace(program-name(1)," ":U, "~~":U).
       
       if  not avail wt-docto
       or  wt-docto.seq-wt-docto <> p-i-seq-wt-docto then do:
           run localizaWtDocto(input  p-i-seq-wt-docto,
                               output l-proc-ok-aux).
           
/*--------------------------------------------------------------------------
    Library    : bodi317.i5
    Purpose    : Include que possui a chamada para a procedure que trata o 
                 retorno dos erros.

    Parameters :

    Notes      :
  ------------------------------------------------------------------------*/

run trataErros(input l-proc-ok-aux, input " ", input ?).
if  not l-proc-ok-aux then return.

/*  BODI317.I5  */
 
       end.
       
       if not avail emitente then do:
           run localizaEmitente(input  wt-docto.cod-emitente,
                                input  wt-docto.nome-abrev, 
                                output l-proc-ok-aux).
           
/*--------------------------------------------------------------------------
    Library    : bodi317.i5
    Purpose    : Include que possui a chamada para a procedure que trata o 
                 retorno dos erros.

    Parameters :

    Notes      :
  ------------------------------------------------------------------------*/

run trataErros(input l-proc-ok-aux, input " ", input ?).
if  not l-proc-ok-aux then return.

/*  BODI317.I5  */
 
       
       end.
       

       if  (emitente.natureza = 3                   /* Estrangeiro                          */
           or emitente.natureza = 4)                  /* Trading                              */
       and param-global.modulo-ex                  /* Exportacao Implantado */
       and wt-docto.esp-docto <> 20               /* notas diferente de devolucao*/
           then do: /* Nr Fatura Exportacao = "Proc Export" */
           if para-fat.ind-docum-fatura = 2 then do:
              for first pre-fatur
                  fields (pre-fatur.cod-dep-ext) no-lock
                  where pre-fatur.cdd-embarq   = wt-docto.cdd-embarq
                  AND   pre-fatur.nr-embarque  = 0 
                  and   pre-fatur.nr-resumo    = wt-docto.nr-resumo:
              end.
       
              /* Verificar se é tranferencia para o porto (dep externo) */
              assign c-cod-dep-ext = if  avail pre-fatur
                                     then pre-fatur.cod-dep-ext
                                     else "":U.
       
              /* evitar esta validacao qdo tiver varios embarques para o mesmo */
              for each tt-epc where tt-epc.cod-event = "VALIDATE-PROCESS": 
                 delete tt-epc. 
              end.
