/*-------------------------------------------------------------------------------------------------------

 Procedimento: validaCriacaoWtDocto.

     Objetivo: Validar a criacao do registro wt-docto.

 Parâmetros de Entrada/Saída:
   Entrada: p-c-cod-estabel....: Cód do estabelecimento
            p-c-serie..........: Série
            p-c-nr-nota........: Número da nota fiscal
            p-c-cod-emitente...: Cód/Nome/CGC do emitente
            p-c-nr-pedcli......: Número do pedido de venda (nr-pedcli)
            p-i-ind-tip-nota...: Tipo da nota
            p-da-dt-emis-nota..: data de emissão da nota
            p-i-nr-embarque....: Número do embarque.
            p-c-nat-operacao...: Natureza de operação que deve ser validada.
            p-i-cod-canal-venda: Código do canal de venda.
   Saída..: p-l-procedimento-ok: Retorna que o procedimento ocorreu por completo.
                      

--------------------------------------------------------------------------------------------------------*/

PROCEDURE validaCriacaoWtDocto:

  /* PROCEDURE validaCriacaoWtDocto: */
  
    /* Definicao de parametros  */
    def input  param p-c-cod-estabel     like nota-fiscal.cod-estabel     no-undo.
    def input  param p-c-serie           like nota-fiscal.serie           no-undo.
    def input  param p-c-nr-nota         like nota-fiscal.nr-nota-fis     no-undo.
    def input  param p-c-cod-emitente    like emitente.nome-abrev         no-undo.
    def input  param p-c-nr-pedcli       like nota-fiscal.nr-pedcli       no-undo.
    def input  param p-i-ind-tip-nota    like nota-fiscal.ind-tip-nota    no-undo.
