/*-------------------------------------------------------------------------------------------------------

 Procedimento: localizaEmitente.

     Objetivo: Localiza o emitente a partir da chave principal.

 Parâmetros de Entrada/Saída:
   Entrada: p-i-cod-emitente...: Código do emitente.
            p-c-nome-abrev.....: Nome abreviado do emitente.
   Saída..: p-l-procedimento-ok: Retorna que o procedimento ocorreu por completo.

 Observação: Para localizar o emitente pelo código deve-se passar "" (brancos) para o p-c-nome-abrev,
             e para localizar o emitente pelo nome abreviado deve-se passar 0 (zero) para o p-i-cod-emitente.
             

--------------------------------------------------------------------------------------------------------*/

PROCEDURE localizaEmitente:
  /*PROCEDURE localizaEmitente:*/
    /* Definição dos parâmetros de Entrada/Saída */
    def input  param p-i-cod-emitente    like emitente.cod-emitente no-undo.
    def input  param p-c-nome-abrev      like emitente.nome-abrev   no-undo.
    def output param p-l-procedimento-ok as   log                   no-undo.

    if  p-c-nome-abrev <> "":U then 
        for first emitente
            fields (emitente.cod-emitente           emitente.nome-abrev
                    emitente.ind-cre-cli            emitente.natureza
                    emitente.identific              emitente.perc-fat-ped
                    emitente.ind-aval-embarque      emitente.ind-aval
                    emitente.estado                 emitente.char-1) no-lock
            where emitente.nome-abrev = p-c-nome-abrev:
        end.
    else
        for first emitente
            fields (emitente.cod-emitente           emitente.nome-abrev
                    emitente.ind-cre-cli            emitente.natureza
                    emitente.identific              emitente.perc-fat-ped
                    emitente.ind-aval-embarque      emitente.ind-aval
                    emitente.estado                 emitente.char-1) no-lock
            where emitente.cod-emitente = p-i-cod-emitente:
        end.    
 

    assign p-l-procedimento-ok = yes. 
/*END PROCEDURE.    */
  /* PROCEDURE localizaEmitente: */
END PROCEDURE.    


