/******************************************************************************
**  NICS0202.I1 - Rotina de Impressao dos Custos dos Itens por Grupo de Estoque
******************************************************************************/

l-primeira = yes.

put "---------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------" skip
    "FARM킗IAS E DROGRARIAS NISSEI S.A.                                                              Custos dos Itens                                                                                                                                               " skip
    "----------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------- " string(today,"99/99/9999") format "x(10)" " - " string(time,"hh:mm:ss") skip(1)
    "Item             Descri눯o                                                    Un Pre뇇 Ult Entrada Ult Entrada    Pre뇇 Base Data Base  M괺io 31/07/2016 M괺io 31/08/2016 Tipo Controle  Cod. Obsoleto" skip                                                          
    "---------------- ------------------------------------------------------------ -- ----------------- ----------- ------------- ---------- ---------------- ---------------- -------------- ----------------------------" skip.
    
for each item use-index grupo where
    item.it-codigo >= c-item-ini and item.it-codigo <= c-item-fim and
    item.ge-codigo >= i-grupo-ini and item.ge-codigo <= i-grupo-fim and
    item.fm-codigo >= c-familia-ini and item.fm-codigo <= c-familia-fim and
    item.desc-item >= c-descr-ini and item.desc-item <= c-descr-fim and
    item.inform-compl >= c-inf-ini and item.inform-compl <= c-inf-fim and
    item.data-implant >= d-data-ini and item.data-implant <= d-data-fim  no-lock
    &IF DEFINED (bf_man_custeio_item) &THEN
        , first item-uni-estab where
                item-uni-estab.it-codigo   = item.it-codigo and
                item-uni-estab.cod-estabel = tt-param.cod-estabel no-lock
    &ENDIF
    on stop undo, leave :
    /*view frame f-cabec-255.
    view frame f-rodape-255.*/ 
           
    if c-opcao-obs = "2" and item.cod-obsoleto > 1 then
        next.
    if c-opcao-obs = "3" and item.cod-obsoleto = 1 then
        next.
    c-descricao = string(item.desc-item).
    find grup-estoque of item no-lock no-error.
    /*if i-grupo-aux <> item.ge-codigo /*or line-counter <= 9 or line-counter > 58*/
    then do:
        if not l-primeira then
           /*page.*/
           put skip(1).
        l-primeira = no.           
                
        display "Grupo de Estoque: " item.ge-codigo "-" 
                grup-estoque.descricao when available grup-estoq no-label skip(1)
                with no-box page-top no-label width 132 stream-io frame f1-cab.

    end.*/

    {intprg/nics0202.i5}
    i-grupo-aux = item.ge-codigo.
end.

/* NICS0202.I1 */
